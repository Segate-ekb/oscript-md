// Inline-парсер CommonMark. Один проход по тексту: для каждого специального символа
// делегирует обработку соответствующему методу. Накопление обычного текста делается
// «лениво» - символ за символом во внутренний буфер, который сбрасывается перед
// генерацией спецузлов.

// Inline-парсер обращается к модулю MarkdownHTMLСущности (lazy-кеш HTML-сущностей)
// при разборе &name;. Имя модуля резолвится на этапе компиляции, поэтому модуль
// должен быть зарегистрирован до загрузки этого файла. Подключаем соседнюю
// internal-подпапку явно - это делает internal/parsing самодостаточным, не
// требуя предварительного подключения фасада.
#Использовать "../../inline"
//
// Реализованы:
//   \X         backslash escapes (CM §6.1)
//   &XYZ; &#N; &#xHH;  entity / numeric refs (CM §6.2)
//   `..`       code spans (CM §6.3)
//   *em* **strong** _em_ __strong__   эмфазис (CM §6.4) - delimiter-stack
//   [text](url "title"), reference & shortcut links (CM §6.3)
//   ![alt](url "title")  изображения
//   <URL> <em@addr>  autolinks (CM §6.5)
//   <tag …>    raw inline HTML (CM §6.6)
//   <space><space>+\n  hard line break (CM §6.7)
//   \<newline> hard line break
//   \n         soft line break (CM §6.8)
//
// Расширения GFM (включаются через MarkdownНастройки.Расширения):
//   ~~text~~   зачёркивание
//   www. http(s)://  extended autolinks

Перем _СсылочныеОпределения;
Перем _ПунктуацияASCII;
Перем _Настройки;              // Переданные извне настройки (для расширений)
Перем _ЗачёркиваниеВключено; // Кеш булево: включено ли расширение strikethrough
Перем _АвтоссылкиВключены;   // Кеш булево: включены ли расширенные автоссылки
Перем _Сущности;               // Lazy-кеш таблицы HTML-сущностей (Соответствие)

// Кешированные регэкспы для inline-конструкций. Все паттерны якорятся через ^
// и применяются к остатку строки начиная с текущей позиции (Сред(Текст, Поз)).
Перем _РегекспURIAutolink;
Перем _РегекспEmailAutolink;
Перем _РегекспHTMLОткрТег;
Перем _РегекспHTMLЗакрТег;
Перем _РегекспHTMLКомментарий;
Перем _РегекспHTMLPI;
Перем _РегекспHTMLДекларация;
Перем _РегекспHTMLCDATA;

// Готовые списки кандидатов в порядке проверки. Раньше они пересобирались
// в Массив при каждом вызове ПопробоватьRawHTML / ПропуститьАвтоссылкуИлиHTMLТег;
// теперь заполняются единожды в ПриСозданииОбъекта.
Перем _КандидатыHTMLТегов;
Перем _КандидатыАвтоссылок;

#Область Открытое

Процедура ИспользоватьСсылочныеОпределения(Знач Определения) Экспорт
    _СсылочныеОпределения = Определения;
КонецПроцедуры

Процедура УстановитьНастройки(Знач НастройкиПарам) Экспорт
    _Настройки = НастройкиПарам;
    Если _Настройки <> Неопределено Тогда
        _ЗачёркиваниеВключено = _Настройки.Расширения.Включено("strikethrough");
        _АвтоссылкиВключены   = _Настройки.Расширения.Включено("autolinks");
    КонецЕсли;
КонецПроцедуры

Функция Разобрать(Знач СыройТекст) Экспорт
    // Состояние единым пакетом передаётся в Обработать*-хелперы. Структура
    // изменяется по ссылке: ХвостПробелов считается инкрементально, чтобы
    // не сканировать буфер при каждом newline. Буфер - массив чанков
    // (обычно по одному символу), который объединяется в Text-узел при сбросе.
    Состояние = Новый Структура("Узлы, Буфер, Делимитеры, ХвостПробелов",
        Новый Массив, Новый Массив, Новый Массив, 0);

    Длина = СтрДлина(СыройТекст);
    Поз = 1;

    Пока Поз <= Длина Цикл
        С = Сред(СыройТекст, Поз, 1);
        НоваяПоз = ДиспетчерСпецСимвола(СыройТекст, Поз, Длина, С, Состояние);
        Если НоваяПоз > 0 Тогда
            Поз = НоваяПоз;
            Продолжить;
        КонецЕсли;

        Состояние.Буфер.Добавить(С);
        Если С = " " Тогда
            Состояние.ХвостПробелов = Состояние.ХвостПробелов + 1;
        Иначе
            Состояние.ХвостПробелов = 0;
        КонецЕсли;
        Поз = Поз + 1;
    КонецЦикла;

    ВыгрузитьБуфер(Состояние.Узлы, Состояние.Буфер);

    // Постобработка: эмфазис/strong через delimiter-stack алгоритм CommonMark.
    ОбработатьЭмфазис(Состояние.Узлы, Состояние.Делимитеры);

    // Удаление nil-плейсхолдеров.
    Возврат Уплотнить(Состояние.Узлы);
КонецФункции

// Диспетчер по «триггерному» символу. Каждый Обработать*-хелпер либо
// возвращает новую позицию (>0), либо 0 - что означает «не сработало,
// добавить C в буфер как обычный символ». Вынесено из Разобрать(), чтобы
// держать главный цикл плоским (когнитивная сложность <= 15).
Функция ДиспетчерСпецСимвола(Знач Текст, Знач Поз, Знач Длина, Знач С, Состояние)
    Если С = "\" Тогда
        Возврат ОбработатьБэкслеш(Текст, Поз, Состояние);
    ИначеЕсли С = "`" Тогда
        Возврат ОбработатьБэктик(Текст, Поз, Состояние);
    ИначеЕсли С = "&" Тогда
        Возврат ОбработатьСущностьВТексте(Текст, Поз, Состояние);
    ИначеЕсли С = "<" Тогда
        Возврат ОбработатьУгол(Текст, Поз, Состояние);
    ИначеЕсли С = "*" Или С = "_" Тогда
        ВыгрузитьБуфер(Состояние.Узлы, Состояние.Буфер);
        Состояние.ХвостПробелов = 0;
        Возврат ОбработатьДелимитерРан(Текст, Поз, С, Состояние.Узлы, Состояние.Делимитеры);
    ИначеЕсли С = "[" Или (С = "!" И Поз + 1 <= Длина И Сред(Текст, Поз + 1, 1) = "[") Тогда
        Возврат ОбработатьСсылкуИлиИзображение(Текст, Поз, Состояние);
    ИначеЕсли С = Символы.ПС Тогда
        Возврат ОбработатьНьюлайн(Текст, Поз, Длина, Состояние);
    ИначеЕсли С = "~" И _ЗачёркиваниеВключено Тогда
        Возврат ОбработатьСтрайктру(Текст, Поз, Состояние);
    ИначеЕсли (С = "h" Или С = "w") И _АвтоссылкиВключены Тогда
        Возврат ОбработатьGFMАвтоссылку(Текст, Поз, Состояние);
    КонецЕсли;
    Возврат 0;
КонецФункции

#КонецОбласти

#Область Обработчики_Символов_Разобрать

Функция ОбработатьБэкслеш(Знач Текст, Знач Поз, Состояние)
    Результат = ПопробоватьЭкранирование(Текст, Поз);
    Если Результат = Неопределено Тогда Возврат 0; КонецЕсли;
    ВыгрузитьБуфер(Состояние.Узлы, Состояние.Буфер);
    Состояние.ХвостПробелов = 0;
    Для Каждого Узел Из Результат.Узлы Цикл
        Состояние.Узлы.Добавить(Узел);
    КонецЦикла;
    Возврат Результат.Позиция;
КонецФункции

Функция ОбработатьБэктик(Знач Текст, Знач Поз, Состояние)
    Результат = ПопробоватьКодСпан(Текст, Поз);
    Если Результат = Неопределено Тогда Возврат 0; КонецЕсли;
    Если Результат.Свойство("Узел") Тогда
        Возврат ЗафиксироватьУзел(Состояние.Узлы, Состояние.Буфер, Состояние.ХвостПробелов, Результат);
    КонецЕсли;
    // Открывающая серия без пары: сохраняем литерал в буфер.
    Состояние.Буфер.Добавить(Результат.Литерал);
    Состояние.ХвостПробелов = 0;
    Возврат Результат.Позиция;
КонецФункции

Функция ОбработатьСущностьВТексте(Знач Текст, Знач Поз, Состояние)
    Результат = ПопробоватьСущность(Текст, Поз);
    Если Результат = Неопределено Тогда Возврат 0; КонецЕсли;
    Состояние.Буфер.Добавить(Результат.Текст);
    Состояние.ХвостПробелов = ХвостПробеловСправа(Результат.Текст, Состояние.ХвостПробелов);
    Возврат Результат.Позиция;
КонецФункции

Функция ОбработатьУгол(Знач Текст, Знач Поз, Состояние)
    Результат = ПопробоватьАвтоссылку(Текст, Поз);
    Если Результат <> Неопределено Тогда
        Возврат ЗафиксироватьУзел(Состояние.Узлы, Состояние.Буфер, Состояние.ХвостПробелов, Результат);
    КонецЕсли;
    Результат = ПопробоватьRawHTML(Текст, Поз);
    Если Результат <> Неопределено Тогда
        Возврат ЗафиксироватьУзел(Состояние.Узлы, Состояние.Буфер, Состояние.ХвостПробелов, Результат);
    КонецЕсли;
    Возврат 0;
КонецФункции

Функция ОбработатьСсылкуИлиИзображение(Знач Текст, Знач Поз, Состояние)
    Результат = ПопробоватьСсылкуИлиИзображение(Текст, Поз);
    Если Результат = Неопределено Тогда Возврат 0; КонецЕсли;
    Возврат ЗафиксироватьУзел(Состояние.Узлы, Состояние.Буфер, Состояние.ХвостПробелов, Результат);
КонецФункции

Функция ОбработатьНьюлайн(Знач Текст, Знач Поз, Знач Длина, Состояние)
    ЖёсткийБрейк = (Состояние.ХвостПробелов >= 2);
    СбросБуфераСТримом(Состояние.Узлы, Состояние.Буфер, Состояние.ХвостПробелов);
    Состояние.ХвостПробелов = 0;
    Если ЖёсткийБрейк Тогда
        Состояние.Узлы.Добавить(Новый MarkdownПереносСтроки());
    Иначе
        Состояние.Узлы.Добавить(Новый MarkdownМягкийПеренос());
    КонецЕсли;
    НовоеПоз = Поз + 1;
    Пока НовоеПоз <= Длина И Сред(Текст, НовоеПоз, 1) = " " Цикл
        НовоеПоз = НовоеПоз + 1;
    КонецЦикла;
    Возврат НовоеПоз;
КонецФункции

Функция ОбработатьСтрайктру(Знач Текст, Знач Поз, Состояние)
    Результат = ПопробоватьЗачёркивание(Текст, Поз);
    Если Результат = Неопределено Тогда Возврат 0; КонецЕсли;
    Возврат ЗафиксироватьУзел(Состояние.Узлы, Состояние.Буфер, Состояние.ХвостПробелов, Результат);
КонецФункции

Функция ОбработатьGFMАвтоссылку(Знач Текст, Знач Поз, Состояние)
    // GFM extended autolinks: https:// http:// www. - должны начинаться с
    // несловного символа (или с начала строки).
    ПредС = ПоследнийСимволБуфера(Состояние.Буфер);
    Если СтрДлина(ПредС) > 0 И ЭтоСловныйСимвол(ПредС) Тогда Возврат 0; КонецЕсли;
    Результат = ПопробоватьРасширеннуюАвтоссылку(Текст, Поз);
    Если Результат = Неопределено Тогда Возврат 0; КонецЕсли;
    Возврат ЗафиксироватьУзел(Состояние.Узлы, Состояние.Буфер, Состояние.ХвостПробелов, Результат);
КонецФункции

#КонецОбласти

#Область Backslash_Escapes

// Возвращает Структуру {Узлы, Позиция} или Неопределено.
Функция ПопробоватьЭкранирование(Знач Текст, Знач Поз)
    Длина = СтрДлина(Текст);
    Если Поз + 1 > Длина Тогда
        Возврат Неопределено;
    КонецЕсли;
    Следующий = Сред(Текст, Поз + 1, 1);

    // Экранирование \\<newline> → hard break.
    Если Следующий = Символы.ПС Тогда
        Узлы = Новый Массив;
        Узлы.Добавить(Новый MarkdownПереносСтроки());
        НовоеПоз = Поз + 2;
        // Skip следующие ведущие пробелы как обычно при перенос строк.
        Пока НовоеПоз <= Длина И Сред(Текст, НовоеПоз, 1) = " " Цикл
            НовоеПоз = НовоеПоз + 1;
        КонецЦикла;
        Возврат Новый Структура("Узлы, Позиция", Узлы, НовоеПоз);
    КонецЕсли;

    // Экранирование ASCII-пунктуации.
    Если СтрНайти(_ПунктуацияASCII, Следующий) > 0 Тогда
        Узлы = Новый Массив;
        Узлы.Добавить(Новый MarkdownТекст(Следующий));
        Возврат Новый Структура("Узлы, Позиция", Узлы, Поз + 2);
    КонецЕсли;

    // Иначе обратный слеш сохраняется как обычный символ.
    Возврат Неопределено;
КонецФункции

#КонецОбласти

#Область Code_Spans

// Возвращает Структуру:
//   {Узел, Позиция}          - найдена парная серия, готовый MarkdownКодInline.
//   {Литерал, Позиция}       - пара не найдена, открывающая серия должна остаться
//                              как литералы (Литерал = N подряд `).
//   Неопределено              - на позиции нет открывающего символа.
Функция ПопробоватьКодСпан(Знач Текст, Знач Поз)
    Длина = СтрДлина(Текст);
    Если Сред(Текст, Поз, 1) <> "`" Тогда
        Возврат Неопределено;
    КонецЕсли;

    // Считаем открывающую серию `.
    Старт = Поз;
    ПозРабочая = Поз;
    Пока ПозРабочая <= Длина И Сред(Текст, ПозРабочая, 1) = "`" Цикл
        ПозРабочая = ПозРабочая + 1;
    КонецЦикла;
    КолВоОткр = ПозРабочая - Старт;

    // Ищем такую же по длине закрывающую серию (не больше, не меньше).
    Курсор = ПозРабочая;
    Пока Курсор <= Длина Цикл
        Если Сред(Текст, Курсор, 1) <> "`" Тогда
            Курсор = Курсор + 1;
            Продолжить;
        КонецЕсли;
        ВнутрСтарт = Курсор;
        Пока Курсор <= Длина И Сред(Текст, Курсор, 1) = "`" Цикл
            Курсор = Курсор + 1;
        КонецЦикла;
        Если Курсор - ВнутрСтарт = КолВоОткр Тогда
            Содержимое = Сред(Текст, ПозРабочая, ВнутрСтарт - ПозРабочая);
            // Нормализация по CM: \n → пробел; затем «обстрипить» один пробел
            // с каждой стороны если содержимое начинается И заканчивается пробелом
            // и содержит непробельный символ.
            Содержимое = СтрЗаменить(Содержимое, Символы.ПС, " ");
            Содержимое = НормализоватьВнутренниеПробелы(Содержимое);
            Узел = Новый MarkdownКодInline(Содержимое);
            Возврат Новый Структура("Узел, Позиция", Узел, Курсор);
        КонецЕсли;
    КонецЦикла;

    // Закрывающая пара не найдена. Возвращаем литерал серии и продвигаем за неё.
    Литерал = Сред(Текст, Старт, КолВоОткр);
    Возврат Новый Структура("Литерал, Позиция", Литерал, ПозРабочая);
КонецФункции

Функция НормализоватьВнутренниеПробелы(Знач Содержимое)
    Если СтрДлина(Содержимое) < 2 Тогда
        Возврат Содержимое;
    КонецЕсли;
    Первый = Лев(Содержимое, 1);
    Последний = Прав(Содержимое, 1);
    Если Первый <> " " Или Последний <> " " Тогда
        Возврат Содержимое;
    КонецЕсли;
    // Должен быть хотя бы один не-пробельный символ.
    ВсёПробелы = Истина;
    Для Н = 1 По СтрДлина(Содержимое) Цикл
        Если Сред(Содержимое, Н, 1) <> " " Тогда
            ВсёПробелы = Ложь;
            Прервать;
        КонецЕсли;
    КонецЦикла;
    Если ВсёПробелы Тогда
        Возврат Содержимое;
    КонецЕсли;
    Возврат Сред(Содержимое, 2, СтрДлина(Содержимое) - 2);
КонецФункции

#КонецОбласти

#Область Entities

// Возвращает Структуру {Текст, Позиция} или Неопределено.
// Заменяет валидную HTML entity на распакованный текст, который потом будет
// экранирован при HTML-рендеринге; либо оставляет как есть, если невалидна.
Функция ПопробоватьСущность(Знач Текст, Знач Поз)
    Длина = СтрДлина(Текст);
    Если Сред(Текст, Поз, 1) <> "&" Тогда
        Возврат Неопределено;
    КонецЕсли;

    Если Поз + 1 <= Длина И Сред(Текст, Поз + 1, 1) = "#" Тогда
        Возврат ПопробоватьЧисловуюСущность(Текст, Поз, Длина);
    КонецЕсли;
    Возврат ПопробоватьИменованнуюСущность(Текст, Поз, Длина);
КонецФункции

// CommonMark §6.2: numeric character reference: &#N; (dec, до 7 цифр)
// или &#xHH; / &#XHH; (hex, до 6 цифр). Код 0 и невалидные точки кода
// заменяются на U+FFFD.
Функция ПопробоватьЧисловуюСущность(Знач Текст, Знач Поз, Знач Длина)
    Старт = Поз + 2;
    Шестнадцатеричная = Ложь;
    Если Старт <= Длина И (Сред(Текст, Старт, 1) = "x" Или Сред(Текст, Старт, 1) = "X") Тогда
        Шестнадцатеричная = Истина;
        Старт = Старт + 1;
    КонецЕсли;
    Курсор = Старт;
    Пока Курсор <= Длина И ЭтоЦифра(Сред(Текст, Курсор, 1), Шестнадцатеричная) Цикл
        Курсор = Курсор + 1;
    КонецЦикла;
    ДлинаЦифр = Курсор - Старт;
    Если ДлинаЦифр = 0
        Или (Шестнадцатеричная И ДлинаЦифр > 6)
        Или (Не Шестнадцатеричная И ДлинаЦифр > 7) Тогда
        Возврат Неопределено;
    КонецЕсли;
    Если Курсор > Длина Или Сред(Текст, Курсор, 1) <> ";" Тогда
        Возврат Неопределено;
    КонецЕсли;
    ЦифрыСтр = Сред(Текст, Старт, ДлинаЦифр);
    КодПункт = ?(Шестнадцатеричная, ЧислоИзHex(ЦифрыСтр), Число(ЦифрыСтр));
    Симв = ?(ЭтоВалиднаяТочкаКода(КодПункт), Символ(КодПункт), Символ(65533));
    Возврат Новый Структура("Текст, Позиция", Симв, Курсор + 1);
КонецФункции

// CommonMark §6.2: named character reference: &name; - по таблице HTML5.
// Возвращает Неопределено, если имя пустое, не закрыто ';' или неизвестно.
Функция ПопробоватьИменованнуюСущность(Знач Текст, Знач Поз, Знач Длина)
    Курсор = Поз + 1;
    Пока Курсор <= Длина И ЭтоБукваИлиЦифра(Сред(Текст, Курсор, 1)) Цикл
        Курсор = Курсор + 1;
    КонецЦикла;
    Если Курсор - Поз - 1 = 0 Или Курсор > Длина Или Сред(Текст, Курсор, 1) <> ";" Тогда
        Возврат Неопределено;
    КонецЕсли;
    Имя = Сред(Текст, Поз + 1, Курсор - Поз - 1);
    Распакованный = ИзвестныеСущности().Получить(Имя);
    Если Распакованный = Неопределено Тогда
        Возврат Неопределено;
    КонецЕсли;
    Возврат Новый Структура("Текст, Позиция", Распакованный, Курсор + 1);
КонецФункции

Функция ЭтоВалиднаяТочкаКода(Знач КодПункт)
    // 0, > U+10FFFF и surrogate pair диапазон U+D800..U+DFFF - заменяются на U+FFFD.
    Если КодПункт = 0 Или КодПункт > 1114111 Тогда Возврат Ложь; КонецЕсли;
    Если КодПункт >= 55296 И КодПункт <= 57343 Тогда Возврат Ложь; КонецЕсли;
    Возврат Истина;
КонецФункции

Функция ЭтоЦифра(Знач С, Знач Hex)
    Если СтрДлина(С) = 0 Тогда Возврат Ложь; КонецЕсли;
    КодС = КодСимвола(С);
    Если КодС >= 48 И КодС <= 57 Тогда Возврат Истина; КонецЕсли;
    Если Hex И ((КодС >= 65 И КодС <= 70) Или (КодС >= 97 И КодС <= 102)) Тогда
        Возврат Истина;
    КонецЕсли;
    Возврат Ложь;
КонецФункции

Функция ЭтоБукваИлиЦифра(Знач С)
    Если СтрДлина(С) = 0 Тогда Возврат Ложь; КонецЕсли;
    КодС = КодСимвола(С);
    Возврат (КодС >= 48 И КодС <= 57) Или (КодС >= 65 И КодС <= 90) Или (КодС >= 97 И КодС <= 122);
КонецФункции

Функция ЧислоИзHex(Знач Стр)
    Результат = 0;
    Для Н = 1 По СтрДлина(Стр) Цикл
        С = НРег(Сред(Стр, Н, 1));
        КодС = КодСимвола(С);
        Цифра = ?(КодС >= 48 И КодС <= 57, КодС - 48, КодС - 87);
        Результат = Результат * 16 + Цифра;
    КонецЦикла;
    Возврат Результат;
КонецФункции

Функция ИзвестныеСущности()
    Если _Сущности = Неопределено Тогда
        _Сущности = MarkdownHTMLСущности.Таблица();
    КонецЕсли;
    Возврат _Сущности;
КонецФункции

#КонецОбласти

#Область Autolinks

Функция ПопробоватьАвтоссылку(Знач Текст, Знач Поз)
    Если Сред(Текст, Поз, 1) <> "<" Тогда
        Возврат Неопределено;
    КонецЕсли;

    Остаток = Сред(Текст, Поз);

    // URI autolink.
    Сов = ПервоеСовпадение(_РегекспURIAutolink, Остаток);
    Если Сов <> Неопределено Тогда
        Содержимое = Сред(Сов, 2, СтрДлина(Сов) - 2);
        Узел = Новый MarkdownСсылка(Содержимое);
        Узел.Добавить(Новый MarkdownТекст(Содержимое));
        Возврат Новый Структура("Узел, Позиция", Узел, Поз + СтрДлина(Сов));
    КонецЕсли;

    // Email autolink.
    Сов = ПервоеСовпадение(_РегекспEmailAutolink, Остаток);
    Если Сов <> Неопределено Тогда
        Содержимое = Сред(Сов, 2, СтрДлина(Сов) - 2);
        Узел = Новый MarkdownСсылка("mailto:" + Содержимое);
        Узел.Добавить(Новый MarkdownТекст(Содержимое));
        Возврат Новый Структура("Узел, Позиция", Узел, Поз + СтрДлина(Сов));
    КонецЕсли;

    Возврат Неопределено;
КонецФункции

Функция ПервоеСовпадение(Знач Регексп, Знач Текст)
    Совпадения = Регексп.НайтиСовпадения(Текст);
    Для Каждого М Из Совпадения Цикл
        Если М.Индекс = 0 Тогда
            Возврат М.Значение;
        КонецЕсли;
        Прервать;
    КонецЦикла;
    Возврат Неопределено;
КонецФункции

Функция ЭтоСловныйСимвол(Знач С)
    // Буква, цифра или подчёркивание - «словный» символ для целей word-boundary.
    Если СтрДлина(С) = 0 Тогда Возврат Ложь; КонецЕсли;
    Если С = "_" Тогда Возврат Истина; КонецЕсли;
    Возврат ЭтоБукваИлиЦифра(С);
КонецФункции

// Расширение "autolinks" (GFM extended autolinks).
// Распознаёт https://, http://, www. в начале «слова».
// Возвращает {Узел: MarkdownСсылка, Позиция} или Неопределено.
Функция ПопробоватьРасширеннуюАвтоссылку(Знач Текст, Знач Поз)
    Длина = СтрДлина(Текст);
    Остаток = Сред(Текст, Поз);

    // Определяем URL и схему.
    Схема = "";
    Если Лев(Остаток, 8) = "https://" Тогда
        Схема = "https://";
    ИначеЕсли Лев(Остаток, 7) = "http://" Тогда
        Схема = "http://";
    ИначеЕсли Лев(Остаток, 4) = "www." Тогда
        Схема = "www.";
    Иначе
        Возврат Неопределено;
    КонецЕсли;

    // Сканируем до символа-стопа.
    Курсор = Поз + СтрДлина(Схема);
    Пока Курсор <= Длина Цикл
        С = Сред(Текст, Курсор, 1);
        КодС = КодСимвола(С);
        // Стоп-символы: пробел, <, >, перевод строки.
        Если С = " " Или С = "<" Или С = ">" Или С = Символы.ПС Или КодС < 33 Тогда
            Прервать;
        КонецЕсли;
        Курсор = Курсор + 1;
    КонецЦикла;

    URLСырой = Сред(Текст, Поз, Курсор - Поз);

    // Убираем trailing punctuation: . , ? ! ; : ) * ~
    Пока СтрДлина(URLСырой) > 0 Цикл
        Хвост = Прав(URLСырой, 1);
        Если СтрНайти(".,?!;:)*~", Хвост) > 0 Тогда
            URLСырой = Лев(URLСырой, СтрДлина(URLСырой) - 1);
            Курсор = Курсор - 1;
        Иначе
            Прервать;
        КонецЕсли;
    КонецЦикла;

    Если СтрДлина(URLСырой) <= СтрДлина(Схема) Тогда
        // URL состоит только из схемы - не распознаём.
        Возврат Неопределено;
    КонецЕсли;

    // Для www. добавляем http:// к href.
    Если Схема = "www." Тогда
        URLHref = "http://" + URLСырой;
    Иначе
        URLHref = URLСырой;
    КонецЕсли;

    Узел = Новый MarkdownСсылка(URLHref);
    Узел.Добавить(Новый MarkdownТекст(URLСырой));
    Возврат Новый Структура("Узел, Позиция", Узел, Курсор);
КонецФункции

#КонецОбласти

#Область GFM_Strikethrough

// Расширение "strikethrough": ~~text~~.
// Возвращает {Узел: MarkdownЗачёркнутый, Позиция} или Неопределено.
Функция ПопробоватьЗачёркивание(Знач Текст, Знач Поз)
    Длина = СтрДлина(Текст);
    // Должны быть ровно "~~" в начале.
    Если Поз + 1 > Длина Тогда Возврат Неопределено; КонецЕсли;
    Если Сред(Текст, Поз, 2) <> "~~" Тогда Возврат Неопределено; КонецЕсли;

    // Ищем закрывающий "~~".
    Курсор = Поз + 2;
    Пока Курсор + 1 <= Длина Цикл
        Если Сред(Текст, Курсор, 2) = "~~" Тогда
            // Содержимое между двумя "~~".
            Содержимое = Сред(Текст, Поз + 2, Курсор - Поз - 2);
            Если СтрДлина(Содержимое) = 0 Тогда
                Возврат Неопределено;
            КонецЕсли;
            Узел = Новый MarkdownЗачёркнутый();
            Дети = РазобратьВложенный(Содержимое);
            Для Каждого Реб Из Дети Цикл
                Узел.Добавить(Реб);
            КонецЦикла;
            Возврат Новый Структура("Узел, Позиция", Узел, Курсор + 2);
        КонецЕсли;
        Курсор = Курсор + 1;
    КонецЦикла;

    Возврат Неопределено;
КонецФункции

#КонецОбласти

#Область Raw_HTML

// CommonMark §6.6: проверяет, начинается ли inline raw HTML с текущей позиции.
// Реализовано через набор регулярных выражений, каждое якорится в начало остатка.
Функция ПопробоватьRawHTML(Знач Текст, Знач Поз)
    Если Сред(Текст, Поз, 1) <> "<" Тогда Возврат Неопределено; КонецЕсли;

    Остаток = Сред(Текст, Поз);

    Для Каждого Регексп Из _КандидатыHTMLТегов Цикл
        Сов = ПервоеСовпадение(Регексп, Остаток);
        Если Сов <> Неопределено Тогда
            Узел = Новый MarkdownHTMLInline(Сов);
            Возврат Новый Структура("Узел, Позиция", Узел, Поз + СтрДлина(Сов));
        КонецЕсли;
    КонецЦикла;

    Возврат Неопределено;
КонецФункции

#КонецОбласти

#Область Ссылки_и_изображения

// Возвращает {Узел, Позиция} или Неопределено для inline-ссылки/картинки
// синтаксиса [text](url "title") или ![alt](url "title").
//
// Reference-формы ([text][label], [label][], [label]) поддерживаются если
// _СсылочныеОпределения содержит соответствующий лейбл; иначе откат до literal.
Функция ПопробоватьСсылкуИлиИзображение(Знач Текст, Знач Поз)
    Длина = СтрДлина(Текст);
    Откр = РаспознатьОткрытиеСсылки(Текст, Поз, Длина);
    Если Откр = Неопределено Тогда Возврат Неопределено; КонецЕсли;

    // Найти соответствующую `]` (учитываем экранирование и вложенные `[`).
    КонецТекста = НайтиЗакрСкобку(Текст, Откр.СтартТекста);
    Если КонецТекста = 0 Тогда Возврат Неопределено; КонецЕсли;

    СодержимоеТекст = Сред(Текст, Откр.СтартТекста, КонецТекста - Откр.СтартТекста);
    ПослеЗакр = КонецТекста + 1;

    // Inline link: после ] идёт (URL "title").
    Если ПослеЗакр <= Длина И Сред(Текст, ПослеЗакр, 1) = "(" Тогда
        Разбор = ПарсингДестинацииИЗаголовка(Текст, ПослеЗакр + 1);
        Если Разбор <> Неопределено Тогда
            Возврат СобратьLinkУзел(Откр.Изображение, Разбор.URL, Разбор.Заголовок,
                СодержимоеТекст, Разбор.Конец);
        КонецЕсли;
    КонецЕсли;

    // Reference / collapsed / shortcut form: вычисляем лейбл и его конец.
    Ссылка = РазрешитьЛейблСсылки(Текст, ПослеЗакр, Длина, СодержимоеТекст);
    Если Ссылка = Неопределено Тогда Возврат Неопределено; КонецЕсли;

    Определение = _СсылочныеОпределения.Получить(Ссылка.Лейбл);
    Если Определение = Неопределено Тогда Возврат Неопределено; КонецЕсли;

    Возврат СобратьLinkУзел(Откр.Изображение, Определение.URL, Определение.Заголовок,
        СодержимоеТекст, Ссылка.КонецСлова + 1);
КонецФункции

// Распознаёт префикс `[` (ссылка) или `![` (изображение). Возвращает
// Структуру {Изображение, СтартТекста} или Неопределено, если префикс
// не соответствует ни одному из двух.
Функция РаспознатьОткрытиеСсылки(Знач Текст, Знач Поз, Знач Длина)
    С = Сред(Текст, Поз, 1);
    Если С = "!" Тогда
        Если Поз + 1 > Длина Или Сред(Текст, Поз + 1, 1) <> "[" Тогда
            Возврат Неопределено;
        КонецЕсли;
        Возврат Новый Структура("Изображение, СтартТекста", Истина, Поз + 2);
    КонецЕсли;
    Если С = "[" Тогда
        Возврат Новый Структура("Изображение, СтартТекста", Ложь, Поз + 1);
    КонецЕсли;
    Возврат Неопределено;
КонецФункции

// Распознаёт reference / collapsed / shortcut форму после закрывающей `]`
// (позиция ПослеЗакр - сразу после неё). Возвращает {Лейбл, КонецСлова}
// либо Неопределено, если форма не распознана.
Функция РазрешитьЛейблСсылки(Знач Текст, Знач ПослеЗакр, Знач Длина, Знач СодержимоеТекст)
    // Collapsed: [text][]
    Если ПослеЗакр + 1 <= Длина И Сред(Текст, ПослеЗакр, 2) = "[]" Тогда
        Возврат Новый Структура("Лейбл, КонецСлова",
            НормализоватьЛейбл(СодержимоеТекст), ПослеЗакр + 1);
    КонецЕсли;
    // Full reference: [text][label]
    Если ПослеЗакр <= Длина И Сред(Текст, ПослеЗакр, 1) = "[" Тогда
        КонецЛейбла = НайтиЗакрСкобку(Текст, ПослеЗакр + 1);
        Если КонецЛейбла = 0 Тогда Возврат Неопределено; КонецЕсли;
        СырЛейбл = Сред(Текст, ПослеЗакр + 1, КонецЛейбла - ПослеЗакр - 1);
        // [text][] (с пробелами как label) считается collapsed.
        Источник = ?(СтрДлина(СокрЛП(СырЛейбл)) > 0, СырЛейбл, СодержимоеТекст);
        Возврат Новый Структура("Лейбл, КонецСлова",
            НормализоватьЛейбл(Источник), КонецЛейбла);
    КонецЕсли;
    // Shortcut: [text]
    Возврат Новый Структура("Лейбл, КонецСлова",
        НормализоватьЛейбл(СодержимоеТекст), ПослеЗакр - 1);
КонецФункции

Функция СобратьLinkУзел(Знач ЭтоИзображение, Знач URL, Знач Заголовок, Знач СодержимоеТекст, Знач НоваяПозиция)
    // Рекурсивный inline-разбор содержимого текста ссылки.
    Дети = РазобратьВложенный(СодержимоеТекст);

    // CM §6.3: правило деактивации - ссылка не может содержать другую ссылку.
    Если Не ЭтоИзображение И СодержитСсылку(Дети) Тогда
        Возврат Неопределено;
    КонецЕсли;

    Если ЭтоИзображение Тогда
        Узел = Новый MarkdownИзображение(URL, Заголовок);
    Иначе
        Узел = Новый MarkdownСсылка(URL, Заголовок);
    КонецЕсли;
    Для Каждого Реб Из Дети Цикл
        Узел.Добавить(Реб);
    КонецЦикла;
    Возврат Новый Структура("Узел, Позиция", Узел, НоваяПозиция);
КонецФункции

// Рекурсивно проверяет, содержит ли набор узлов (или их потомки) узел-ссылку.
Функция СодержитСсылку(Знач Узлы)
    ТипСсылки = Тип("MarkdownСсылка");
    Для Каждого Узел Из Узлы Цикл
        Если ТипЗнч(Узел) = ТипСсылки Тогда
            Возврат Истина;
        КонецЕсли;
        Если Узел.Дети.Количество() > 0 И СодержитСсылку(Узел.Дети) Тогда
            Возврат Истина;
        КонецЕсли;
    КонецЦикла;
    Возврат Ложь;
КонецФункции

Функция РазобратьВложенный(Знач Текст)
    Вложенный = Новый MarkdownInlineПарсер();
    Вложенный.ИспользоватьСсылочныеОпределения(_СсылочныеОпределения);
    Вложенный.УстановитьНастройки(_Настройки);
    Возврат Вложенный.Разобрать(Текст);
КонецФункции

// Сканирует с позиции `Поз` и возвращает позицию соответствующей `]`,
// либо 0 если не нашли. Учитывает обратный слеш и вложенные `[`.
Функция НайтиЗакрСкобку(Знач Текст, Знач Поз)
    Длина = СтрДлина(Текст);
    Глубина = 1;
    Пока Поз <= Длина Цикл
        С = Сред(Текст, Поз, 1);
        Если С = "\" Тогда
            Поз = Поз + 2;
            Продолжить;
        ИначеЕсли С = "[" Тогда
            Глубина = Глубина + 1;
        ИначеЕсли С = "]" Тогда
            Глубина = Глубина - 1;
            Если Глубина = 0 Тогда Возврат Поз; КонецЕсли;
        ИначеЕсли С = "`" Тогда
            // Пропуск code span - содержимое его не участвует в скобках.
            Тилы = ПропуститьCodeSpan(Текст, Поз);
            Если Тилы > Поз Тогда Поз = Тилы; Продолжить; КонецЕсли;
        ИначеЕсли С = "<" Тогда
            // Пропуск автоссылки или raw HTML-тега - скобки внутри них игнорируются.
            КонецТега = ПропуститьАвтоссылкуИлиHTMLТег(Текст, Поз);
            Если КонецТега > Поз Тогда Поз = КонецТега; Продолжить; КонецЕсли;
        КонецЕсли;
        Поз = Поз + 1;
    КонецЦикла;
    Возврат 0;
КонецФункции

// Пропускает автоссылку (<URI> или <email>) или raw HTML-тег, начинающийся с '<'.
// Возвращает позицию сразу после закрывающего '>' или ту же Поз если не распознано.
Функция ПропуститьАвтоссылкуИлиHTMLТег(Знач Текст, Знач Поз)
    Если Сред(Текст, Поз, 1) <> "<" Тогда Возврат Поз; КонецЕсли;
    Остаток = Сред(Текст, Поз);

    // Автоссылки.
    Для Каждого Регексп Из _КандидатыАвтоссылок Цикл
        Сов = ПервоеСовпадение(Регексп, Остаток);
        Если Сов <> Неопределено Тогда Возврат Поз + СтрДлина(Сов); КонецЕсли;
    КонецЦикла;

    // Raw HTML-теги.
    Для Каждого Регексп Из _КандидатыHTMLТегов Цикл
        Сов = ПервоеСовпадение(Регексп, Остаток);
        Если Сов <> Неопределено Тогда Возврат Поз + СтрДлина(Сов); КонецЕсли;
    КонецЦикла;

    Возврат Поз;
КонецФункции

Функция ПропуститьCodeSpan(Знач Текст, Знач Поз)
    Длина = СтрДлина(Текст);
    Если Сред(Текст, Поз, 1) <> "`" Тогда Возврат Поз; КонецЕсли;
    Старт = Поз;
    Пока Поз <= Длина И Сред(Текст, Поз, 1) = "`" Цикл Поз = Поз + 1; КонецЦикла;
    Кол = Поз - Старт;
    Курс = Поз;
    Пока Курс <= Длина Цикл
        Если Сред(Текст, Курс, 1) = "`" Тогда
            СтартЗ = Курс;
            Пока Курс <= Длина И Сред(Текст, Курс, 1) = "`" Цикл Курс = Курс + 1; КонецЦикла;
            Если Курс - СтартЗ = Кол Тогда Возврат Курс; КонецЕсли;
        Иначе
            Курс = Курс + 1;
        КонецЕсли;
    КонецЦикла;
    Возврат Старт;
КонецФункции

// Парсит "URL" или "URL "title"" или "URL 'title'" или "URL (title)".
// Возвращает {URL, Заголовок, Конец} (позиция после `)`).
Функция ПарсингДестинацииИЗаголовка(Знач Текст, Знач Поз)
    Длина = СтрДлина(Текст);

    // Skip optional whitespace (включая до 1 переноса).
    Поз = ПропуститьПробельныеВТ(Текст, Поз);

    // Parse destination.
    Если Поз > Длина Тогда Возврат Неопределено; КонецЕсли;
    Назн = ПарсингДестинации(Текст, Поз);
    Если Назн = Неопределено Тогда Возврат Неопределено; КонецЕсли;
    Поз = Назн.Конец;

    // Optional title после пробельных.
    Загол = "";
    ПозПослеПробелов = ПропуститьПробельныеВТ(Текст, Поз);
    Если ПозПослеПробелов > Поз Тогда
        // Между URL и title должен быть пробел/таб/перенос.
        Загзагол = ПарсингЗаголовка(Текст, ПозПослеПробелов);
        Если Загзагол <> Неопределено Тогда
            Загол = Загзагол.Заголовок;
            Поз = Загзагол.Конец;
        КонецЕсли;
    КонецЕсли;

    Поз = ПропуститьПробельныеВТ(Текст, Поз);
    Если Поз > Длина Или Сред(Текст, Поз, 1) <> ")" Тогда Возврат Неопределено; КонецЕсли;

    Возврат Новый Структура("URL, Заголовок, Конец",
        Назн.URL, Загол, Поз + 1);
КонецФункции

Функция ПропуститьПробельныеВТ(Знач Текст, Знач Поз)
    Длина = СтрДлина(Текст);
    КолПереносов = 0;
    Пока Поз <= Длина Цикл
        С = Сред(Текст, Поз, 1);
        Если С = " " Или С = Символы.Таб Тогда
            Поз = Поз + 1;
        ИначеЕсли С = Символы.ПС Тогда
            КолПереносов = КолПереносов + 1;
            Если КолПереносов > 1 Тогда Прервать; КонецЕсли;
            Поз = Поз + 1;
        Иначе
            Прервать;
        КонецЕсли;
    КонецЦикла;
    Возврат Поз;
КонецФункции

// Парсит link destination: <url> или non-bracket-form.
Функция ПарсингДестинации(Знач Текст, Знач Поз)
    Длина = СтрДлина(Текст);
    Если Поз > Длина Тогда Возврат Неопределено; КонецЕсли;
    Если Сред(Текст, Поз, 1) = "<" Тогда
        Курс = Поз + 1;
        Накоп = Новый Массив;
        Пока Курс <= Длина Цикл
            С = Сред(Текст, Курс, 1);
            Если С = ">" Тогда
                Возврат Новый Структура("URL, Конец",
                    РасшифроватьЭкранирование(СтрСоединить(Накоп, "")), Курс + 1);
            ИначеЕсли С = "<" Или С = Символы.ПС Тогда
                Возврат Неопределено;
            ИначеЕсли С = "\" И Курс + 1 <= Длина Тогда
                След = Сред(Текст, Курс + 1, 1);
                Если СтрНайти(_ПунктуацияASCII, След) > 0 Тогда
                    Накоп.Добавить(След); Курс = Курс + 2; Продолжить;
                КонецЕсли;
            КонецЕсли;
            Накоп.Добавить(С);
            Курс = Курс + 1;
        КонецЦикла;
        Возврат Неопределено;
    КонецЕсли;

    // Без угловых скобок: до пробела/нерационального символа.
    Курс = Поз;
    Накоп = Новый Массив;
    Глубина = 0;
    Пока Курс <= Длина Цикл
        С = Сред(Текст, Курс, 1);
        Если С = " " Или С = Символы.Таб Или С = Символы.ПС Тогда Прервать; КонецЕсли;
        Если С = "(" Тогда Глубина = Глубина + 1;
        ИначеЕсли С = ")" Тогда
            Если Глубина = 0 Тогда Прервать; КонецЕсли;
            Глубина = Глубина - 1;
        ИначеЕсли С = "\" И Курс + 1 <= Длина Тогда
            След = Сред(Текст, Курс + 1, 1);
            Если СтрНайти(_ПунктуацияASCII, След) > 0 Тогда
                Накоп.Добавить(След); Курс = Курс + 2; Продолжить;
            КонецЕсли;
        КонецЕсли;
        КодС = КодСимвола(С);
        Если КодС < 32 Тогда Прервать; КонецЕсли;
        Накоп.Добавить(С);
        Курс = Курс + 1;
    КонецЦикла;
    Возврат Новый Структура("URL, Конец",
        РасшифроватьЭкранирование(СтрСоединить(Накоп, "")), Курс);
КонецФункции

Функция ПарсингЗаголовка(Знач Текст, Знач Поз)
    Длина = СтрДлина(Текст);
    Если Поз > Длина Тогда Возврат Неопределено; КонецЕсли;
    Откр = Сред(Текст, Поз, 1);
    Закр = "";
    Если Откр = """" Тогда Закр = """";
    ИначеЕсли Откр = "'" Тогда Закр = "'";
    ИначеЕсли Откр = "(" Тогда Закр = ")";
    Иначе Возврат Неопределено;
    КонецЕсли;
    Курс = Поз + 1;
    Накоп = Новый Массив;
    Пока Курс <= Длина Цикл
        С = Сред(Текст, Курс, 1);
        Если С = Закр Тогда
            Возврат Новый Структура("Заголовок, Конец",
                РасшифроватьЭкранирование(СтрСоединить(Накоп, "")), Курс + 1);
        ИначеЕсли С = "\" И Курс + 1 <= Длина Тогда
            След = Сред(Текст, Курс + 1, 1);
            Если СтрНайти(_ПунктуацияASCII, След) > 0 Тогда
                Накоп.Добавить(След); Курс = Курс + 2; Продолжить;
            КонецЕсли;
        КонецЕсли;
        Накоп.Добавить(С);
        Курс = Курс + 1;
    КонецЦикла;
    // Title-парсинг не закрылся → Неопределено (для inline ссылок).
    Возврат Неопределено;
КонецФункции

Функция РасшифроватьЭкранирование(Знач Текст)
    // Decode entity references в URL/title (CM рекомендует распаковать перед рендером).
    Длина = СтрДлина(Текст);
    Части = Новый Массив;
    Н = 1;
    Пока Н <= Длина Цикл
        С = Сред(Текст, Н, 1);
        Если С = "&" Тогда
            Расш = ПопробоватьСущность(Текст, Н);
            Если Расш <> Неопределено Тогда
                Части.Добавить(Расш.Текст);
                Н = Расш.Позиция;
                Продолжить;
            КонецЕсли;
        КонецЕсли;
        Части.Добавить(С);
        Н = Н + 1;
    КонецЦикла;
    Возврат СтрСоединить(Части, "");
КонецФункции

Функция НормализоватьЛейбл(Знач Текст) Экспорт
    Результат = ВРег(СокрЛП(Текст));
    // Unicode case-folding: символы, раскрывающиеся в несколько ASCII-букв (CM §6.9).
    Результат = СтрЗаменить(Результат, Символ(223),  "SS"); // ß  (U+00DF)
    Результат = СтрЗаменить(Результат, Символ(7838), "SS"); // ẞ  (U+1E9E)
    // Свернуть последовательные whitespace в один пробел.
    Части = Новый Массив;
    ПредПробел = Ложь;
    Для Н = 1 По СтрДлина(Результат) Цикл
        С = Сред(Результат, Н, 1);
        Если С = " " Или С = Символы.Таб Или С = Символы.ПС Тогда
            Если Не ПредПробел Тогда Части.Добавить(" "); КонецЕсли;
            ПредПробел = Истина;
        Иначе
            Части.Добавить(С);
            ПредПробел = Ложь;
        КонецЕсли;
    КонецЦикла;
    Возврат СтрСоединить(Части, "");
КонецФункции

#КонецОбласти

#Область Emphasis_Delimiter_Stack

// Обработать серию * или _ начиная с позиции Поз. Возвращает новую позицию.
// Добавляет MarkdownТекст с литералами в Узлы и одну запись в Делимитеры
// (Структура: Символ, Длина, Активен, МожетОткрыть, МожетЗакрыть, Узел).
Функция ОбработатьДелимитерРан(Знач Текст, Знач Поз, Знач Симв, Узлы, Делимитеры)
    Длина = СтрДлина(Текст);
    Старт = Поз;
    Пока Поз <= Длина И Сред(Текст, Поз, 1) = Симв Цикл
        Поз = Поз + 1;
    КонецЦикла;
    Кол = Поз - Старт;

    ПредСимв = ?(Старт > 1, Сред(Текст, Старт - 1, 1), Символы.ПС);
    СледСимв = ?(Поз <= Длина, Сред(Текст, Поз, 1), Символы.ПС);

    Lflank = ЛевоФланкинг(ПредСимв, СледСимв);
    Rflank = ПравоФланкинг(ПредСимв, СледСимв);

    Если Симв = "*" Тогда
        МожетОткрыть = Lflank;
        МожетЗакрыть = Rflank;
    Иначе
        МожетОткрыть = Lflank И (Не Rflank Или ЭтоПунктуация(ПредСимв));
        МожетЗакрыть = Rflank И (Не Lflank Или ЭтоПунктуация(СледСимв));
    КонецЕсли;

    Узел = Новый MarkdownТекст(Сред(Текст, Старт, Кол));
    Узлы.Добавить(Узел);

    Запись = Новый Структура("Символ, Длина, Активен, МожетОткрыть, МожетЗакрыть, Узел",
        Симв, Кол, Истина, МожетОткрыть, МожетЗакрыть, Узел);
    Делимитеры.Добавить(Запись);

    Возврат Поз;
КонецФункции

Функция ЛевоФланкинг(Знач Пред, Знач След)
    Если ЭтоПробельный(След) Тогда Возврат Ложь; КонецЕсли;
    Если Не ЭтоПунктуация(След) Тогда Возврат Истина; КонецЕсли;
    Возврат ЭтоПробельный(Пред) Или ЭтоПунктуация(Пред);
КонецФункции

Функция ПравоФланкинг(Знач Пред, Знач След)
    Если ЭтоПробельный(Пред) Тогда Возврат Ложь; КонецЕсли;
    Если Не ЭтоПунктуация(Пред) Тогда Возврат Истина; КонецЕсли;
    Возврат ЭтоПробельный(След) Или ЭтоПунктуация(След);
КонецФункции

Функция ЭтоПробельный(Знач С)
    Если СтрДлина(С) = 0 Тогда Возврат Истина; КонецЕсли;
    Если С = " " Или С = Символы.Таб Или С = Символы.ПС Или С = Символы.ВК
        Или С = Символ(12) Или С = Символ(160) Тогда
        Возврат Истина;
    КонецЕсли;
    Возврат Ложь;
КонецФункции

Функция ЭтоПунктуация(Знач С)
    Если СтрДлина(С) = 0 Тогда Возврат Ложь; КонецЕсли;
    Если СтрНайти(_ПунктуацияASCII, С) > 0 Тогда Возврат Истина; КонецЕсли;
    // Часть Unicode-punctuation/symbol для flanking-проверок CM §6.6
    // (Sc - currency, P/S - общая пунктуация).
    Код = КодСимвола(С);
    Если (Код >= 161 И Код <= 191)                   // Latin-1 punct/symbols ¡-¿
        Или (Код >= 8192 И Код <= 8303)             // General Punctuation U+2000..U+206F
        Или (Код >= 8352 И Код <= 8399)             // Currency Symbols   U+20A0..U+20CF
        Или Код = 215 Или Код = 247 Тогда           // × ÷
        Возврат Истина;
    КонецЕсли;
    Возврат Ложь;
КонецФункции

// Реализация CommonMark §6.6 process_emphasis.
Процедура ОбработатьЭмфазис(Узлы, Делимитеры)
    Если Делимитеры.Количество() = 0 Тогда Возврат; КонецЕсли;

    // Iterate over closers from start.
    Закр = 0;
    Пока Закр < Делимитеры.Количество() Цикл
        Зак = Делимитеры[Закр];
        Если Не Зак.Активен Или Не Зак.МожетЗакрыть Тогда
            Закр = Закр + 1;
            Продолжить;
        КонецЕсли;

        // Поиск opener - обратный проход без bottom-оптимизации
        // (правильная индексация openers_bottom требует 6-ключевой структуры,
        // что усложняет код; для корректности проходим всю историю).
        НайденОткр = Ложь;
        ИндексОткр = -1;
        Откр = Закр - 1;
        Пока Откр >= 0 Цикл
            О = Делимитеры[Откр];
            Если О.Активен И О.МожетОткрыть И О.Символ = Зак.Символ Тогда
                // Правило 9-10 CommonMark.
                ПлохоеПравило = (О.МожетЗакрыть Или Зак.МожетОткрыть)
                    И ((О.Длина + Зак.Длина) % 3 = 0)
                    И Не ((О.Длина % 3 = 0) И (Зак.Длина % 3 = 0));
                Если Не ПлохоеПравило Тогда
                    НайденОткр = Истина;
                    ИндексОткр = Откр;
                    Прервать;
                КонецЕсли;
            КонецЕсли;
            Откр = Откр - 1;
        КонецЦикла;

        Если Не НайденОткр Тогда
            Если Не Зак.МожетОткрыть Тогда
                Зак.Активен = Ложь;
            КонецЕсли;
            Закр = Закр + 1;
            Продолжить;
        КонецЕсли;

        О = Делимитеры[ИндексОткр];
        Strong = (О.Длина >= 2 И Зак.Длина >= 2);
        Съесть = ?(Strong, 2, 1);

        // Создаём emphasis/strong узел, оборачивающий узлы между О.Узел и Зак.Узел.
        ОбернутьМеждуУзлами(Узлы, О.Узел, Зак.Узел, Strong);

        // Шорт-каты: уменьшаем длины, обновляем текстовые узлы.
        О.Длина = О.Длина - Съесть;
        Зак.Длина = Зак.Длина - Съесть;
        ПодровнятьТекстУзла(О.Узел, О.Символ, О.Длина);
        ПодровнятьТекстУзла(Зак.Узел, Зак.Символ, Зак.Длина);

        // Удалить все промежуточные delimiter-записи (они «съедены» вложенным контентом).
        Для Н = ИндексОткр + 1 По Закр - 1 Цикл
            Делимитеры[Н].Активен = Ложь;
        КонецЦикла;

        // Если opener пуст - удаляем его узел и саму запись.
        Если О.Длина = 0 Тогда
            УдалитьУзелИзСписка(Узлы, О.Узел);
            О.Активен = Ложь;
        КонецЕсли;
        // Если closer пуст - удаляем узел; не продвигаем Закр (следующий по индексу
        // станет текущим). Иначе тот же closer ещё может матчиться с другими openers.
        Если Зак.Длина = 0 Тогда
            УдалитьУзелИзСписка(Узлы, Зак.Узел);
            Зак.Активен = Ложь;
            Закр = Закр + 1;
        КонецЕсли;
        // Иначе остаёмся на том же Закр.
    КонецЦикла;
КонецПроцедуры

Процедура ОбернутьМеждуУзлами(Узлы, ОткрУзел, ЗакрУзел, Strong)
    ИндО = НайтиИндексУзла(Узлы, ОткрУзел);
    ИндЗ = НайтиИндексУзла(Узлы, ЗакрУзел);
    Если ИндО < 0 Или ИндЗ < 0 Или ИндО >= ИндЗ Тогда Возврат; КонецЕсли;

    Обёртка = ?(Strong, Новый MarkdownЖирный(), Новый MarkdownКурсив());
    Для Н = ИндО + 1 По ИндЗ - 1 Цикл
        Если Узлы[Н] <> Неопределено Тогда
            Обёртка.Добавить(Узлы[Н]);
            Узлы[Н] = Неопределено;
        КонецЕсли;
    КонецЦикла;
    // Вставляем wrapper непосредственно после opener.
    Узлы[ИндО + 1] = Обёртка;
КонецПроцедуры

Функция НайтиИндексУзла(Узлы, Узел)
    Для Н = 0 По Узлы.Количество() - 1 Цикл
        Если Узлы[Н] = Узел Тогда Возврат Н; КонецЕсли;
    КонецЦикла;
    Возврат -1;
КонецФункции

Процедура ПодровнятьТекстУзла(Узел, Знач Символ, Знач Длина)
    Если Длина <= 0 Тогда
        Узел.Значение = "";
        Возврат;
    КонецЕсли;
    Части = Новый Массив;
    Для Н = 1 По Длина Цикл Части.Добавить(Символ); КонецЦикла;
    Узел.Значение = СтрСоединить(Части, "");
КонецПроцедуры

Процедура УдалитьУзелИзСписка(Узлы, Узел)
    Индекс = НайтиИндексУзла(Узлы, Узел);
    Если Индекс >= 0 Тогда
        Узлы[Индекс] = Неопределено;
    КонецЕсли;
КонецПроцедуры

Функция Уплотнить(Узлы)
    Результат = Новый Массив;
    Для Каждого У Из Узлы Цикл
        Если У <> Неопределено Тогда
            Результат.Добавить(У);
        КонецЕсли;
    КонецЦикла;
    Возврат Результат;
КонецФункции

#КонецОбласти

#Область Буфер

// Сбрасывает накопленный буфер как один Text-узел и очищает массив.
Процедура ВыгрузитьБуфер(Узлы, Буфер)
    Если Буфер.Количество() > 0 Тогда
        Узлы.Добавить(Новый MarkdownТекст(СтрСоединить(Буфер, "")));
        Буфер.Очистить();
    КонецЕсли;
КонецПроцедуры

// Общий путь для успешных результатов inline-парсеров в Разобрать():
// выгружает накопленный текст, сбрасывает счётчик пробелов, добавляет
// узел из результата и возвращает позицию для продолжения скана.
Функция ЗафиксироватьУзел(Узлы, Буфер, ХвостПробеловПарам, Знач Результат)
    ВыгрузитьБуфер(Узлы, Буфер);
    ХвостПробеловПарам = 0;
    Узлы.Добавить(Результат.Узел);
    Возврат Результат.Позиция;
КонецФункции

// Сбрасывает буфер, предварительно срезав хвостовые пробелы. Используется
// перед softbreak/hardbreak в Разобрать(): trailing spaces - это разметка
// hard break, в Text-узел они не попадают.
Процедура СбросБуфераСТримом(Узлы, Буфер, Знач ХвостПробелов)
    Если Буфер.Количество() = 0 Тогда Возврат; КонецЕсли;
    Строка = СтрСоединить(Буфер, "");
    Если ХвостПробелов > 0 Тогда
        Строка = Лев(Строка, СтрДлина(Строка) - ХвостПробелов);
    КонецЕсли;
    Буфер.Очистить();
    Если СтрДлина(Строка) > 0 Тогда
        Узлы.Добавить(Новый MarkdownТекст(Строка));
    КонецЕсли;
КонецПроцедуры

// Обновляет счётчик хвостовых пробелов после добавления многосимвольного чанка
// (entity result). Если в чанке встретился не-пробел - счётчик начинается заново
// с трейлинга чанка; иначе суммируется.
Функция ХвостПробеловСправа(Знач Чанк, Знач СтарХвост)
    Длина = СтрДлина(Чанк);
    Если Длина = 0 Тогда Возврат СтарХвост; КонецЕсли;
    Хвост = 0;
    Поз = Длина;
    Пока Поз > 0 И Сред(Чанк, Поз, 1) = " " Цикл
        Хвост = Хвост + 1;
        Поз = Поз - 1;
    КонецЦикла;
    Если Хвост = Длина Тогда
        Возврат СтарХвост + Хвост;
    КонецЕсли;
    Возврат Хвост;
КонецФункции

Функция ПоследнийСимволБуфера(Знач Буфер)
    Если Буфер.Количество() = 0 Тогда Возврат ""; КонецЕсли;
    ПослЧанк = Буфер[Буфер.Количество() - 1];
    Возврат Прав(ПослЧанк, 1);
КонецФункции

#КонецОбласти

Процедура ПриСозданииОбъекта()
    _СсылочныеОпределения = Новый Соответствие;
    _ПунктуацияASCII = "!""#$%&'()*+,-./:;<=>?@[\]^_`{|}~";
    _Настройки = Неопределено;
    _ЗачёркиваниеВключено = Ложь;
    _АвтоссылкиВключены   = Ложь;
    _Сущности = Неопределено;
    ИнициализироватьРегекспы();
КонецПроцедуры

// Сборка скомпилированных регэкспов для autolink/HTML-tag-форм. Выделено из
// ПриСозданииОбъекта, чтобы конструктор был коротким и читаемым.
Процедура ИнициализироватьРегекспы()
    // CommonMark §6.5: URI-autolink - scheme [A-Za-z][A-Za-z0-9+.-]{1,31} ':' …
    _РегекспURIAutolink = Новый РегулярноеВыражение(
        "^<[A-Za-z][A-Za-z0-9+.\-]{1,31}:[^<>␀- ]*>");

    // CommonMark §6.5: email autolink.
    _РегекспEmailAutolink = Новый РегулярноеВыражение(
        "^<[a-zA-Z0-9.!#$%&'*+/=?^_`{|}~\-]+"
        + "@[a-zA-Z0-9](?:[a-zA-Z0-9\-]{0,61}[a-zA-Z0-9])?"
        + "(?:\.[a-zA-Z0-9](?:[a-zA-Z0-9\-]{0,61}[a-zA-Z0-9])?)*>");

    // CM §6.6 - открывающий тег.
    _РегекспHTMLОткрТег = Новый РегулярноеВыражение(
        "^<[A-Za-z][A-Za-z0-9\-]*"
        + "(?:[ \t\r\n]+[A-Za-z_:][A-Za-z0-9_.:\-]*"
        + "(?:[ \t\r\n]*=[ \t\r\n]*"
        + "(?:[^ \t\r\n""'=<>`]+|'[^']*'|""[^""]*""))?)*"
        + "[ \t\r\n]*/?>");

    _РегекспHTMLЗакрТег = Новый РегулярноеВыражение(
        "^</[A-Za-z][A-Za-z0-9\-]*[ \t\r\n]*>");

    // CM 0.31.2 §6.6 - HTML comment. Допустимы три формы:
    //   <!-->          (литерал)
    //   <!--->         (литерал)
    //   <!--…-->       произвольное тело, заканчивающееся ПЕРВЫМ '-->'.
    _РегекспHTMLКомментарий = Новый РегулярноеВыражение(
        "^(?:<!-->|<!--->|<!--[\s\S]*?-->)");

    _РегекспHTMLPI = Новый РегулярноеВыражение(
        "^<\?[\s\S]*?\?>");

    _РегекспHTMLДекларация = Новый РегулярноеВыражение(
        "^<![A-Za-z][^>]*>");

    _РегекспHTMLCDATA = Новый РегулярноеВыражение(
        "^<!\[CDATA\[[\s\S]*?\]\]>");

    // Порядок важен: CDATA / комментарий / PI / декларация - раньше открывающего
    // тега, иначе "<!ELEMENT" мог бы пройти как имя тега.
    _КандидатыHTMLТегов = Новый Массив;
    _КандидатыHTMLТегов.Добавить(_РегекспHTMLКомментарий);
    _КандидатыHTMLТегов.Добавить(_РегекспHTMLCDATA);
    _КандидатыHTMLТегов.Добавить(_РегекспHTMLPI);
    _КандидатыHTMLТегов.Добавить(_РегекспHTMLДекларация);
    _КандидатыHTMLТегов.Добавить(_РегекспHTMLЗакрТег);
    _КандидатыHTMLТегов.Добавить(_РегекспHTMLОткрТег);

    _КандидатыАвтоссылок = Новый Массив;
    _КандидатыАвтоссылок.Добавить(_РегекспURIAutolink);
    _КандидатыАвтоссылок.Добавить(_РегекспEmailAutolink);
КонецПроцедуры

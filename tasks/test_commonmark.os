// Прогон автогенерируемых CommonMark-сьютов через OneUnit.
//
// Запуск:
//   oscript tasks/test_commonmark.os
//
// Каталог tests/commonmark/<версия> заполняется генератором
// (tools/sync-commonmark.ps1) — один файл на секцию спецификации.
//
// Выход: 0 при успехе, !=0 при падении. xfail-тесты помечены аннотацией
// &Выключен("причина") и не приводят к падению CI.

#Использовать 1commands

ПутьКОтчетуJUnit = ОбъединитьПути(".", "build", "reports", "junit-commonmark.xml");
КаталогОтчетов   = ОбъединитьПути(".", "build", "reports");

ФайлКаталога = Новый Файл(КаталогОтчетов);
Если Не ФайлКаталога.Существует() Тогда
    СоздатьКаталог(КаталогОтчетов);
КонецЕсли;

Команда = Новый Команда;
Команда.УстановитьКоманду("oneunit");
Команда.ДобавитьПараметр("execute");
Команда.ДобавитьПараметр("-d tests/commonmark");
Команда.ДобавитьПараметр("-r");
Команда.ДобавитьПараметр("--mode summary");
// --junit отключён: oneunit падает на ']]>' в тестовых данных (raw HTML CDATA).
// Включить обратно, когда тесты CDATA будут отфильтрованы или баг oneunit исправлен.
// Команда.ДобавитьПараметр("--junit " + ПутьКОтчетуJUnit);
Команда.ПоказыватьВыводНемедленно(Истина);

КодВозврата = Команда.Исполнить();

Если КодВозврата <> 0 Тогда
    ВызватьИсключение "CommonMark-тесты завершились неудачно";
КонецЕсли;

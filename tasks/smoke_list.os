#Использовать "../src"

Настройки = Новый MarkdownНастройки("commonmark");

Сообщить("--- 123456789. ok ---");
Сообщить(Markdown.ВHTML("123456789. ok", Настройки));
Сообщить("--- 0. ok ---");
Сообщить(Markdown.ВHTML("0. ok", Настройки));
Сообщить("--- 003. ok ---");
Сообщить(Markdown.ВHTML("003. ok", Настройки));
Сообщить("--- - foo / - / - bar ---");
Сообщить(Markdown.ВHTML("- foo" + Символы.ПС + "-" + Символы.ПС + "- bar", Настройки));

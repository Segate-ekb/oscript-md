// Прогон unit-тестов проекта через OneUnit. Создаёт JUnit-отчёт для CI.
//
// Запуск:
//   oscript tasks/test_unit.os
//
// Выход: 0 при успехе, !=0 при падении.

#Использовать 1commands

ПутьКОтчетуJUnit = ОбъединитьПути(".", "build", "reports", "junit-unit.xml");
КаталогОтчетов   = ОбъединитьПути(".", "build", "reports");

ФайлКаталога = Новый Файл(КаталогОтчетов);
Если Не ФайлКаталога.Существует() Тогда
    СоздатьКаталог(КаталогОтчетов);
КонецЕсли;

Команда = Новый Команда;
Команда.УстановитьКоманду("oneunit");
Команда.ДобавитьПараметр("execute");
Команда.ДобавитьПараметр("-d tests/unit");
Команда.ДобавитьПараметр("-r");
Команда.ДобавитьПараметр("--junit " + ПутьКОтчетуJUnit);
Команда.ПоказыватьВыводНемедленно(Истина);

КодВозврата = Команда.Исполнить();

Если КодВозврата <> 0 Тогда
    ВызватьИсключение "Юнит-тесты завершились неудачно";
КонецЕсли;

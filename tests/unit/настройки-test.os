#Использовать asserts
#Использовать "../../src"

// Тесты конфигурации парсера: пресеты, расширения, безопасный режим.

&Тест
Процедура Тест_Настройки_ПоУмолчанию_БезопасныйРежимВключен() Экспорт
    Настройки = Новый MarkdownНастройки();

    Утверждения.ПроверитьИстину(Настройки.БезопасныйРежим,
        "По умолчанию библиотека должна быть безопасной");
    Утверждения.ПроверитьЛожь(Настройки.РазрешитьRawHTML,
        "raw HTML по умолчанию выключен");
КонецПроцедуры

&Тест
Процедура Тест_Настройки_Пресет_CommonMark() Экспорт
    Настройки = Новый MarkdownНастройки("commonmark");

    Утверждения.ПроверитьРавенство("commonmark", Настройки.Пресет);
    Утверждения.ПроверитьЛожь(Настройки.Расширения.Включено("tables"),
        "Пресет commonmark не должен включать tables");
КонецПроцедуры

&Тест
Процедура Тест_Настройки_Пресет_GitHubLike_ВключаетТаблицыИЗадачи() Экспорт
    Настройки = Новый MarkdownНастройки("github-like");

    Утверждения.ПроверитьРавенство("github-like", Настройки.Пресет);
    Утверждения.ПроверитьИстину(Настройки.Расширения.Включено("tables"));
    Утверждения.ПроверитьИстину(Настройки.Расширения.Включено("tasklists"));
КонецПроцедуры

&Тест
Процедура Тест_НаборРасширений_ВключитьОтключить() Экспорт
    Набор = Новый MarkdownНаборРасширений();

    Утверждения.ПроверитьЛожь(Набор.Включено("tables"));

    Набор.Включить("tables");
    Утверждения.ПроверитьИстину(Набор.Включено("tables"));

    Набор.Отключить("tables");
    Утверждения.ПроверитьЛожь(Набор.Включено("tables"));
КонецПроцедуры

&Тест
Процедура Тест_НаборРасширений_СписокВозвращаетИменаВключённых() Экспорт
    Набор = Новый MarkdownНаборРасширений();
    Набор.Включить("tables");
    Набор.Включить("strikethrough");

    Список = Набор.Список();

    Утверждения.ПроверитьРавенство(2, Список.Количество());
    Утверждения.ПроверитьИстину(Список.Найти("tables") <> Неопределено);
    Утверждения.ПроверитьИстину(Список.Найти("strikethrough") <> Неопределено);
КонецПроцедуры

&Тест
Процедура Тест_Настройки_НевалидныйПресетВыдаётИсключение() Экспорт
    Утверждения.ПроверитьКодСОшибкой(
        "Настройки = Новый MarkdownНастройки(""unknown-preset"");",
        "пресет");
КонецПроцедуры

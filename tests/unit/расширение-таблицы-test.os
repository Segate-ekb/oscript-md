#Использовать asserts
#Использовать "../../src"
#Использовать "../../src/internal/parsing"
#Использовать "../../src/internal/extensions"

// Тесты расширения tables: парсер GFM-таблиц и HTML-рендеринг.
// Блочный парсер тестируется изолированно через контракт МожетРазобрать/Разобрать.
// Интеграционные тесты проверяют сквозной рендеринг через фасад.
// Internal-подпапки подключаются явно для прямого доступа к MarkdownКонтекстПарсинга
// (internal/parsing) и MarkdownПарсерТаблиц (internal/extensions).

Функция КонтекстДляСтрок(Знач Исходник)
    Возврат Новый MarkdownКонтекстПарсинга(Исходник);
КонецФункции

Функция GHНастройки()
    Возврат Markdown.НастройкиGitHubLike();
КонецФункции

#Область МожетРазобрать

&Тест
Процедура Тест_Таблица_МожетРазобрать_ПростаяТаблица() Экспорт
    Исходник = "| Кол1 | Кол2 |" + Символы.ПС + "|------|------|";
    Контекст = КонтекстДляСтрок(Исходник);
    Парсер = Новый MarkdownПарсерТаблиц();

    Утверждения.ПроверитьИстину(Парсер.МожетРазобрать(Контекст));
КонецПроцедуры

&Тест
Процедура Тест_Таблица_МожетРазобрать_БезПайпа() Экспорт
    Контекст = КонтекстДляСтрок("обычный параграф");
    Парсер = Новый MarkdownПарсерТаблиц();

    Утверждения.ПроверитьЛожь(Парсер.МожетРазобрать(Контекст));
КонецПроцедуры

&Тест
Процедура Тест_Таблица_МожетРазобрать_ПайпНоБезРазделителя() Экспорт
    // Вторая строка — не разделитель, значит это не таблица.
    Исходник = "| Кол1 | Кол2 |" + Символы.ПС + "| Ячейка | Ячейка |";
    Контекст = КонтекстДляСтрок(Исходник);
    Парсер = Новый MarkdownПарсерТаблиц();

    Утверждения.ПроверитьЛожь(Парсер.МожетРазобрать(Контекст));
КонецПроцедуры

&Тест
Процедура Тест_Таблица_МожетРазобрать_ОднаКолонка() Экспорт
    Исходник = "| Кол |" + Символы.ПС + "|-----|";
    Контекст = КонтекстДляСтрок(Исходник);
    Парсер = Новый MarkdownПарсерТаблиц();

    Утверждения.ПроверитьИстину(Парсер.МожетРазобрать(Контекст));
КонецПроцедуры

#КонецОбласти

#Область Разобрать_Структура

&Тест
Процедура Тест_Таблица_Разобрать_ТипУзла() Экспорт
    Исходник = "| A | B |" + Символы.ПС + "|---|---|";
    Контекст = КонтекстДляСтрок(Исходник);
    Парсер = Новый MarkdownПарсерТаблиц();

    Таблица = Парсер.Разобрать(Контекст);

    Утверждения.ПроверитьРавенство("table", Таблица.ТипУзла());
КонецПроцедуры

&Тест
Процедура Тест_Таблица_Разобрать_ЕстьСтрокаЗаголовка() Экспорт
    Исходник = "| A | B |" + Символы.ПС + "|---|---|";
    Контекст = КонтекстДляСтрок(Исходник);
    Парсер = Новый MarkdownПарсерТаблиц();

    Таблица = Парсер.Разобрать(Контекст);

    Утверждения.ПроверитьРавенство(1, Таблица.Дети.Количество(), "Только заголовок, тело пустое");
    Утверждения.ПроверитьРавенство("table_row", Таблица.Дети[0].ТипУзла());
    Утверждения.ПроверитьИстину(Таблица.Дети[0].ЭтоЗаголовок);
КонецПроцедуры

&Тест
Процедура Тест_Таблица_Разобрать_ЯчейкиЗаголовка() Экспорт
    Исходник = "| Кол1 | Кол2 |" + Символы.ПС + "|------|------|";
    Контекст = КонтекстДляСтрок(Исходник);
    Парсер = Новый MarkdownПарсерТаблиц();

    Таблица = Парсер.Разобрать(Контекст);
    СтрЗагол = Таблица.Дети[0];

    Утверждения.ПроверитьРавенство(2, СтрЗагол.Дети.Количество());
    Утверждения.ПроверитьРавенство("Кол1", СтрЗагол.Дети[0].ИсходныйТекст);
    Утверждения.ПроверитьРавенство("Кол2", СтрЗагол.Дети[1].ИсходныйТекст);
КонецПроцедуры

&Тест
Процедура Тест_Таблица_Разобрать_СтрокаДанных() Экспорт
    Исходник =
        "| A | B |" + Символы.ПС +
        "|---|---|" + Символы.ПС +
        "| X | Y |";
    Контекст = КонтекстДляСтрок(Исходник);
    Парсер = Новый MarkdownПарсерТаблиц();

    Таблица = Парсер.Разобрать(Контекст);

    // Заголовок + 1 строка данных.
    Утверждения.ПроверитьРавенство(2, Таблица.Дети.Количество());
    СтрДанных = Таблица.Дети[1];
    Утверждения.ПроверитьЛожь(СтрДанных.ЭтоЗаголовок);
    Утверждения.ПроверитьРавенство("X", СтрДанных.Дети[0].ИсходныйТекст);
    Утверждения.ПроверитьРавенство("Y", СтрДанных.Дети[1].ИсходныйТекст);
КонецПроцедуры

&Тест
Процедура Тест_Таблица_Разобрать_НескольколСтрокДанных() Экспорт
    Исходник =
        "| A |" + Символы.ПС +
        "|---|" + Символы.ПС +
        "| 1 |" + Символы.ПС +
        "| 2 |" + Символы.ПС +
        "| 3 |";
    Контекст = КонтекстДляСтрок(Исходник);
    Парсер = Новый MarkdownПарсерТаблиц();

    Таблица = Парсер.Разобрать(Контекст);

    // Заголовок + 3 строки данных.
    Утверждения.ПроверитьРавенство(4, Таблица.Дети.Количество());
КонецПроцедуры

&Тест
Процедура Тест_Таблица_Разобрать_ТипЯчейки() Экспорт
    Исходник = "| A |" + Символы.ПС + "|---|";
    Контекст = КонтекстДляСтрок(Исходник);
    Парсер = Новый MarkdownПарсерТаблиц();

    Таблица = Парсер.Разобрать(Контекст);
    Ячейка = Таблица.Дети[0].Дети[0];

    Утверждения.ПроверитьРавенство("table_cell", Ячейка.ТипУзла());
КонецПроцедуры

#КонецОбласти

#Область Разобрать_Выравнивания

&ПараметризованныйТест
&ИсточникЗначение("|---|",    "")
&ИсточникЗначение("|:---|",   "left")
&ИсточникЗначение("|---:|",   "right")
&ИсточникЗначение("|:---:|",  "center")
Процедура Тест_Таблица_Выравнивание(СтрРазделитель, ОжидаемоеВыравн) Экспорт
    Исходник = "| Кол |" + Символы.ПС + СтрРазделитель;
    Контекст = КонтекстДляСтрок(Исходник);
    Парсер = Новый MarkdownПарсерТаблиц();

    Таблица = Парсер.Разобрать(Контекст);
    Ячейка = Таблица.Дети[0].Дети[0];

    Утверждения.ПроверитьРавенство(ОжидаемоеВыравн, Ячейка.Выравнивание);
КонецПроцедуры

#КонецОбласти

#Область HTML_Рендеринг

&Тест
Процедура Тест_Таблица_HTML_СтруктураТегов() Экспорт
    МД = "| A | B |" + Символы.ПС + "|---|---|" + Символы.ПС + "| X | Y |";

    HTML = Markdown.ВHTML(МД, GHНастройки());

    Утверждения.ПроверитьИстину(СтрНайти(HTML, "<table>") > 0);
    Утверждения.ПроверитьИстину(СтрНайти(HTML, "</table>") > 0);
    Утверждения.ПроверитьИстину(СтрНайти(HTML, "<thead>") > 0);
    Утверждения.ПроверитьИстину(СтрНайти(HTML, "</thead>") > 0);
    Утверждения.ПроверитьИстину(СтрНайти(HTML, "<tbody>") > 0);
    Утверждения.ПроверитьИстину(СтрНайти(HTML, "</tbody>") > 0);
КонецПроцедуры

&Тест
Процедура Тест_Таблица_HTML_ЯчейкиЗаголовка() Экспорт
    МД = "| A | B |" + Символы.ПС + "|---|---|" + Символы.ПС + "| X | Y |";

    HTML = Markdown.ВHTML(МД, GHНастройки());

    Утверждения.ПроверитьИстину(СтрНайти(HTML, "<th>A</th>") > 0);
    Утверждения.ПроверитьИстину(СтрНайти(HTML, "<th>B</th>") > 0);
КонецПроцедуры

&Тест
Процедура Тест_Таблица_HTML_ЯчейкиТела() Экспорт
    МД = "| A | B |" + Символы.ПС + "|---|---|" + Символы.ПС + "| X | Y |";

    HTML = Markdown.ВHTML(МД, GHНастройки());

    Утверждения.ПроверитьИстину(СтрНайти(HTML, "<td>X</td>") > 0);
    Утверждения.ПроверитьИстину(СтрНайти(HTML, "<td>Y</td>") > 0);
КонецПроцедуры

&ПараметризованныйТест
&ИсточникЗначение("|:---:|", "center")
&ИсточникЗначение("|---:|",  "right")
&ИсточникЗначение("|:---|",  "left")
Процедура Тест_Таблица_HTML_АтрибутВыравнивания(СтрРазделитель, ОжидаемоеВыравн) Экспорт
    МД = "| A |" + Символы.ПС + СтрРазделитель + Символы.ПС + "| X |";

    HTML = Markdown.ВHTML(МД, GHНастройки());

    Утверждения.ПроверитьИстину(СтрНайти(HTML, "align=""" + ОжидаемоеВыравн + """") > 0);
КонецПроцедуры

&Тест
Процедура Тест_Таблица_HTML_БезВыравниванияНетАтрибута() Экспорт
    МД = "| A |" + Символы.ПС + "|---|" + Символы.ПС + "| X |";

    HTML = Markdown.ВHTML(МД, GHНастройки());

    Утверждения.ПроверитьЛожь(СтрНайти(HTML, "align=") > 0,
        "Без выравнивания атрибут align не должен присутствовать");
КонецПроцедуры

&Тест
Процедура Тест_Таблица_HTML_НеРаботаетБезРасширения() Экспорт
    МД = "| A | B |" + Символы.ПС + "|---|---|" + Символы.ПС + "| X | Y |";

    // Настройки по умолчанию — расширение tables выключено.
    HTML = Markdown.ВHTML(МД);

    Утверждения.ПроверитьЛожь(СтрНайти(HTML, "<table>") > 0,
        "Таблица не должна рендериться без расширения tables");
КонецПроцедуры

#КонецОбласти

#Использовать asserts
#Использовать "../../src"

// Сквозные тесты фасада Markdown: входная точка библиотеки.
// Они защищают от регрессий в композиции: парсер → AST → рендерер.

#Область ВHTML

&Тест
Процедура Тест_Фасад_ВHTML_ATXЗаголовок() Экспорт
    HTML = Markdown.ВHTML("# Привет");

    Утверждения.ПроверитьРавенство("<h1>Привет</h1>" + Символы.ПС, HTML);
КонецПроцедуры

&Тест
Процедура Тест_Фасад_ВHTML_Параграф() Экспорт
    HTML = Markdown.ВHTML("просто текст");

    Утверждения.ПроверитьРавенство("<p>просто текст</p>" + Символы.ПС, HTML);
КонецПроцедуры

&Тест
Процедура Тест_Фасад_ВHTML_ГоризонтальнаяЛиния() Экспорт
    HTML = Markdown.ВHTML("---");

    Утверждения.ПроверитьРавенство("<hr />" + Символы.ПС, HTML);
КонецПроцедуры

&Тест
Процедура Тест_Фасад_ВHTML_НесколькоБлоков() Экспорт
    Исходник =
        "# Заголовок"   + Символы.ПС +
        ""              + Символы.ПС +
        "Параграф один" + Символы.ПС +
        ""              + Символы.ПС +
        "---"           + Символы.ПС +
        ""              + Символы.ПС +
        "Параграф два";

    HTML = Markdown.ВHTML(Исходник);

    Ожидаемый =
        "<h1>Заголовок</h1>"    + Символы.ПС +
        "<p>Параграф один</p>"  + Символы.ПС +
        "<hr />"                + Символы.ПС +
        "<p>Параграф два</p>"   + Символы.ПС;

    Утверждения.ПроверитьРавенство(Ожидаемый, HTML);
КонецПроцедуры

&Тест
Процедура Тест_Фасад_ВHTML_ПустойВходДаётПустоеHTML() Экспорт
    Утверждения.ПроверитьРавенство("", Markdown.ВHTML(""));
КонецПроцедуры

&Тест
Процедура Тест_Фасад_ВHTML_ЭкранируетОпасныеСимволыВТексте() Экспорт
    HTML = Markdown.ВHTML("a < b & c");

    Утверждения.ПроверитьРавенство("<p>a &lt; b &amp; c</p>" + Символы.ПС, HTML);
КонецПроцедуры

#КонецОбласти

#Область Разобрать

&Тест
Процедура Тест_Фасад_Разобрать_ВозвращаетAST() Экспорт
    Документ = Markdown.Разобрать("# Hi");

    Утверждения.ПроверитьТип(Документ, "MarkdownДокумент");
    Утверждения.ПроверитьРавенство(1, Документ.Дети.Количество());
    Утверждения.ПроверитьРавенство("heading", Документ.Дети[0].ТипУзла());
    Утверждения.ПроверитьРавенство(1, Документ.Дети[0].Уровень);
КонецПроцедуры

#КонецОбласти

#Область ВJSON

&Тест
Процедура Тест_Фасад_ВJSON_СтандартныйРезультат() Экспорт
    JSON = Markdown.ВJSON("# Hi");

    Утверждения.ПроверитьВхождение(JSON, """type"":""document""");
    Утверждения.ПроверитьВхождение(JSON, """type"":""heading""");
    Утверждения.ПроверитьВхождение(JSON, """level"":1");
    Утверждения.ПроверитьВхождение(JSON, """value"":""Hi""");
КонецПроцедуры

#КонецОбласти

#Область ВТекст

&Тест
Процедура Тест_Фасад_ВТекст_ИзвлекаетПростойТекст() Экспорт
    Текст = Markdown.ВТекст("# Заголовок" + Символы.ПС + "" + Символы.ПС + "Параграф");

    Утверждения.ПроверитьВхождение(Текст, "Заголовок");
    Утверждения.ПроверитьВхождение(Текст, "Параграф");
    Утверждения.ПроверитьЛожь(СтрНайти(Текст, "#") > 0,
        "Plain text не должен содержать markdown-разметку");
КонецПроцедуры

#КонецОбласти

#Область Безопасность

&Тест
Процедура Тест_Фасад_ВHTML_БезопасныйРежимПоУмолчанию_НеПропускаетRawHTML() Экспорт
    HTML = Markdown.ВHTML("<script>alert(1)</script>");

    Утверждения.ПроверитьЛожь(СтрНайти(НРег(HTML), "<script>") > 0,
        "raw <script> должен быть экранирован в безопасном режиме");
КонецПроцедуры

#КонецОбласти

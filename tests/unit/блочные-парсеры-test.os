#Использовать asserts
#Использовать "../../src"
#Использовать "../../src/internal/parsing"
#Использовать "../../src/internal/block"

// Тесты блочных парсеров: ATX-заголовки, горизонтальные линии, параграфы.
// Каждый парсер тестируется изолированно через свой контракт МожетРазобрать/Разобрать.
// Подпапки internal/parsing и internal/block подключаются явно: они хранят
// классы реализации (контекст парсинга и блочные парсеры), которые для рядовых
// пользователей библиотеки скрыты, но нужны для unit-тестов внутренних деталей.

Функция КонтекстДляСтрок(Знач Исходник)
    Возврат Новый MarkdownКонтекстПарсинга(Исходник);
КонецФункции

#Область ATX_Заголовки

&Тест
Процедура Тест_ATX_МожетРазобратьОднуРешётку() Экспорт
    Контекст = КонтекстДляСтрок("# заголовок");
    Парсер = Новый MarkdownПарсерЗаголовковATX();

    Утверждения.ПроверитьИстину(Парсер.МожетРазобрать(Контекст));
КонецПроцедуры

&ПараметризованныйТест
&ИсточникЗначение("# foo",       1, "foo")
&ИсточникЗначение("## foo",      2, "foo")
&ИсточникЗначение("### foo",     3, "foo")
&ИсточникЗначение("#### foo",    4, "foo")
&ИсточникЗначение("##### foo",   5, "foo")
&ИсточникЗначение("###### foo",  6, "foo")
Процедура Тест_ATX_РазбираетУровниОт1До6(Исходник, ОжидаемыйУровень, ОжидаемыйТекст) Экспорт
    Контекст = КонтекстДляСтрок(Исходник);
    Парсер = Новый MarkdownПарсерЗаголовковATX();

    Узел = Парсер.Разобрать(Контекст);

    Утверждения.ПроверитьРавенство("heading", Узел.ТипУзла());
    Утверждения.ПроверитьРавенство(ОжидаемыйУровень, Узел.Уровень);
    // Inline-фаза не запускается на отдельном парсере; проверяем сырое содержимое.
    Утверждения.ПроверитьРавенство(ОжидаемыйТекст, Узел.ИсходныйТекст);
КонецПроцедуры

&Тест
Процедура Тест_ATX_СемьРешётокНеЯвляютсяЗаголовком() Экспорт
    // CommonMark example #65: ####### foo → параграф, не заголовок.
    Контекст = КонтекстДляСтрок("####### foo");
    Парсер = Новый MarkdownПарсерЗаголовковATX();

    Утверждения.ПроверитьЛожь(Парсер.МожетРазобрать(Контекст));
КонецПроцедуры

&Тест
Процедура Тест_ATX_ТребуетПробелПослеРешёток() Экспорт
    // CommonMark example #66: #5 bolt не должен быть заголовком (нет пробела).
    Контекст = КонтекстДляСтрок("#5 bolt");
    Парсер = Новый MarkdownПарсерЗаголовковATX();

    Утверждения.ПроверитьЛожь(Парсер.МожетРазобрать(Контекст));
КонецПроцедуры

&Тест
Процедура Тест_ATX_УдаляетЗакрывающиеРешётки() Экспорт
    // CommonMark example #74: ## foo ##  → <h2>foo</h2>
    Контекст = КонтекстДляСтрок("## foo ##");
    Парсер = Новый MarkdownПарсерЗаголовковATX();

    Узел = Парсер.Разобрать(Контекст);

    Утверждения.ПроверитьРавенство(2, Узел.Уровень);
    Утверждения.ПроверитьРавенство("foo", Узел.ИсходныйТекст);
КонецПроцедуры

&Тест
Процедура Тест_ATX_ПустойЗаголовокДопустим() Экспорт
    // CommonMark example #79: ## → <h2></h2>
    Контекст = КонтекстДляСтрок("##");
    Парсер = Новый MarkdownПарсерЗаголовковATX();

    Узел = Парсер.Разобрать(Контекст);

    Утверждения.ПроверитьРавенство(2, Узел.Уровень);
    Утверждения.ПроверитьРавенство("", Узел.ИсходныйТекст);
КонецПроцедуры

#КонецОбласти

#Область Горизонтальные_Линии

&ПараметризованныйТест
&ИсточникЗначение("***")
&ИсточникЗначение("---")
&ИсточникЗначение("___")
&ИсточникЗначение("* * *")
&ИсточникЗначение("-  -  -")
&ИсточникЗначение(" ***")
&ИсточникЗначение("  ***")
&ИсточникЗначение("   ***")
Процедура Тест_ThematicBreak_РаспознаётВалидныеВарианты(Исходник) Экспорт
    Контекст = КонтекстДляСтрок(Исходник);
    Парсер = Новый MarkdownПарсерГоризонтальныхЛиний();

    Утверждения.ПроверитьИстину(Парсер.МожетРазобрать(Контекст),
        "Должна быть распознана как линия: '" + Исходник + "'");

    Узел = Парсер.Разобрать(Контекст);
    Утверждения.ПроверитьРавенство("thematic_break", Узел.ТипУзла());
КонецПроцедуры

&ПараметризованныйТест
&ИсточникЗначение("**")
&ИсточникЗначение("--")
&ИсточникЗначение("__")
&ИсточникЗначение("*")
&ИсточникЗначение("    ***")
&ИсточникЗначение("a***")
Процедура Тест_ThematicBreak_ОтклоняетНевалидные(Исходник) Экспорт
    Контекст = КонтекстДляСтрок(Исходник);
    Парсер = Новый MarkdownПарсерГоризонтальныхЛиний();

    Утверждения.ПроверитьЛожь(Парсер.МожетРазобрать(Контекст),
        "Не должна быть линией: '" + Исходник + "'");
КонецПроцедуры

#КонецОбласти

#Область Параграфы

&Тест
Процедура Тест_Параграф_РазбираетОднуСтроку() Экспорт
    Контекст = КонтекстДляСтрок("Это параграф");
    Парсер = Новый MarkdownПарсерПараграфов();

    Утверждения.ПроверитьИстину(Парсер.МожетРазобрать(Контекст));

    Узел = Парсер.Разобрать(Контекст);
    Утверждения.ПроверитьРавенство("paragraph", Узел.ТипУзла());
    // Inline-фаза не запускается на отдельном парсере; проверяем сырое.
    Утверждения.ПроверитьРавенство("Это параграф", Узел.ИсходныйТекст);
КонецПроцедуры

&Тест
Процедура Тест_Параграф_ОбъединяетПоследовательныеСтроки() Экспорт
    Контекст = КонтекстДляСтрок("Строка один" + Символы.ПС + "Строка два");
    Парсер = Новый MarkdownПарсерПараграфов();

    Узел = Парсер.Разобрать(Контекст);

    // Параграф собирает «сырые» строки; инлайн потом разбивает их при необходимости.
    Утверждения.ПроверитьРавенство("paragraph", Узел.ТипУзла());
    Утверждения.ПроверитьРавенство("Строка один" + Символы.ПС + "Строка два", Узел.ИсходныйТекст);
КонецПроцедуры

&Тест
Процедура Тест_Параграф_ОстанавливаетсяНаПустойСтроке() Экспорт
    Контекст = КонтекстДляСтрок("Текст" + Символы.ПС + "" + Символы.ПС + "Следующий");
    Парсер = Новый MarkdownПарсерПараграфов();

    Узел = Парсер.Разобрать(Контекст);

    Утверждения.ПроверитьРавенство("Текст", Узел.ИсходныйТекст);
    // После разбора параграфа контекст должен быть на пустой строке.
    Утверждения.ПроверитьИстину(Контекст.ТекущаяСтрокаПустая(),
        "Курсор контекста должен оказаться на пустой строке");
КонецПроцедуры

#КонецОбласти

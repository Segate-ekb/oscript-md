#Использовать asserts
#Использовать "../../src"

// Тесты AST-узлов: проверяют контракт MarkdownУзел и его наследников.

&Тест
Процедура Тест_Документ_СоздаётсяБезДетей() Экспорт
    Документ = Новый MarkdownДокумент();

    Утверждения.ПроверитьРавенство("document", Документ.ТипУзла());
    Утверждения.ПроверитьИстину(Документ.ЭтоБлочный(), "Документ должен быть блочным узлом");
    Утверждения.ПроверитьЛожь(Документ.ЭтоInline(), "Документ не является inline");
    Утверждения.ПроверитьРавенство(0, Документ.Дети.Количество());
КонецПроцедуры

&Тест
Процедура Тест_Документ_ДобавляетДочерниеУзлыИУстанавливаетРодителя() Экспорт
    Документ = Новый MarkdownДокумент();
    Заголовок = Новый MarkdownЗаголовок(1);

    Документ.Добавить(Заголовок);

    Утверждения.ПроверитьРавенство(1, Документ.Дети.Количество());
    Утверждения.ПроверитьРавенство(Заголовок, Документ.Дети[0]);
    Утверждения.ПроверитьРавенство(Документ, Заголовок.Родитель);
КонецПроцедуры

&Тест
Процедура Тест_Заголовок_ХранитУровень() Экспорт
    Заголовок = Новый MarkdownЗаголовок(3);

    Утверждения.ПроверитьРавенство("heading", Заголовок.ТипУзла());
    Утверждения.ПроверитьРавенство(3, Заголовок.Уровень);
    Утверждения.ПроверитьИстину(Заголовок.ЭтоБлочный());
КонецПроцедуры

&ПараметризованныйТест
&ИсточникЗначение(0)
&ИсточникЗначение(7)
&ИсточникЗначение(-1)
Процедура Тест_Заголовок_ОтклоняетНевалидныйУровень(НевалидныйУровень) Экспорт
    Утверждения.ПроверитьКодСОшибкой(
        "Заголовок = Новый MarkdownЗаголовок(" + НевалидныйУровень + ");",
        "уровень");
КонецПроцедуры

&Тест
Процедура Тест_Параграф_СодержитInlineДетей() Экспорт
    Параграф = Новый MarkdownПараграф();
    Текст = Новый MarkdownТекст("Привет");

    Параграф.Добавить(Текст);

    Утверждения.ПроверитьРавенство("paragraph", Параграф.ТипУзла());
    Утверждения.ПроверитьИстину(Параграф.ЭтоБлочный());
    Утверждения.ПроверитьРавенство(1, Параграф.Дети.Количество());
    Утверждения.ПроверитьРавенство(Текст, Параграф.Дети[0]);
КонецПроцедуры

&Тест
Процедура Тест_Текст_ХранитЗначение() Экспорт
    Текст = Новый MarkdownТекст("привет");

    Утверждения.ПроверитьРавенство("text", Текст.ТипУзла());
    Утверждения.ПроверитьРавенство("привет", Текст.Значение);
    Утверждения.ПроверитьЛожь(Текст.ЭтоБлочный());
    Утверждения.ПроверитьИстину(Текст.ЭтоInline());
КонецПроцедуры

&Тест
Процедура Тест_ГоризонтальнаяЛиния_ТипУзла() Экспорт
    Линия = Новый MarkdownГоризонтальнаяЛиния();

    Утверждения.ПроверитьРавенство("thematic_break", Линия.ТипУзла());
    Утверждения.ПроверитьИстину(Линия.ЭтоБлочный());
    Утверждения.ПроверитьРавенство(0, Линия.Дети.Количество(),
        "Горизонтальная линия не должна иметь детей");
КонецПроцедуры

&Тест
Процедура Тест_Позиция_СохраняетСтрокиИКолонки() Экспорт
    Позиция = Новый MarkdownПозицияВИсходнике(2, 1, 2, 5);

    Утверждения.ПроверитьРавенство(2, Позиция.НачальнаяСтрока);
    Утверждения.ПроверитьРавенство(1, Позиция.НачальнаяКолонка);
    Утверждения.ПроверитьРавенство(2, Позиция.КонечнаяСтрока);
    Утверждения.ПроверитьРавенство(5, Позиция.КонечнаяКолонка);
КонецПроцедуры

&Тест
Процедура Тест_Узел_ХранитПозицию() Экспорт
    Заголовок = Новый MarkdownЗаголовок(1);
    Заголовок.Позиция = Новый MarkdownПозицияВИсходнике(5, 1, 5, 8);

    Утверждения.ПроверитьРавенство(5, Заголовок.Позиция.НачальнаяСтрока);
    Утверждения.ПроверитьРавенство(8, Заголовок.Позиция.КонечнаяКолонка);
КонецПроцедуры

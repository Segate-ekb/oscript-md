#Использовать asserts
#Использовать "../../src"

// Тесты расширения tasklists: постпроцессор и HTML-рендеринг.
// Постпроцессор проверяется через AST (Markdown.Разобрать), рендеринг — через фасад.

Функция GHНастройки()
    Возврат Markdown.НастройкиGitHubLike();
КонецФункции

#Область Постпроцессор_Метаданные

&Тест
Процедура Тест_Задачи_ПомечаетНевыполненную() Экспорт
    Документ = Markdown.Разобрать("- [ ] Задача", GHНастройки());

    Элемент = Документ.Дети[0].Дети[0];

    Утверждения.ПроверитьИстину(Элемент.ЭтоЗадача);
    Утверждения.ПроверитьЛожь(Элемент.Выполнено);
КонецПроцедуры

&Тест
Процедура Тест_Задачи_ПомечаетВыполненную_x() Экспорт
    Документ = Markdown.Разобрать("- [x] Сделано", GHНастройки());

    Элемент = Документ.Дети[0].Дети[0];

    Утверждения.ПроверитьИстину(Элемент.ЭтоЗадача);
    Утверждения.ПроверитьИстину(Элемент.Выполнено);
КонецПроцедуры

&Тест
Процедура Тест_Задачи_ПомечаетВыполненную_X_Заглавный() Экспорт
    // GFM допускает [X] как «выполнено».
    Документ = Markdown.Разобрать("- [X] Сделано", GHНастройки());

    Элемент = Документ.Дети[0].Дети[0];

    Утверждения.ПроверитьИстину(Элемент.ЭтоЗадача);
    Утверждения.ПроверитьИстину(Элемент.Выполнено);
КонецПроцедуры

&Тест
Процедура Тест_Задачи_НеПомечаетОбычныйЭлемент() Экспорт
    Документ = Markdown.Разобрать("- Обычный элемент", GHНастройки());

    Элемент = Документ.Дети[0].Дети[0];

    Утверждения.ПроверитьЛожь(Элемент.ЭтоЗадача);
КонецПроцедуры

&Тест
Процедура Тест_Задачи_НеПомечаетБезПробелаПослеСкобки() Экспорт
    // "[x]текст" без пробела после ] — не задача.
    Документ = Markdown.Разобрать("- [x]текст", GHНастройки());

    Элемент = Документ.Дети[0].Дети[0];

    Утверждения.ПроверитьЛожь(Элемент.ЭтоЗадача);
КонецПроцедуры

&Тест
Процедура Тест_Задачи_СмешанныйСписок() Экспорт
    МД =
        "- [ ] Первая" + Символы.ПС +
        "- [x] Вторая" + Символы.ПС +
        "- Обычная";
    Документ = Markdown.Разобрать(МД, GHНастройки());

    Список = Документ.Дети[0];
    Утверждения.ПроверитьИстину(Список.Дети[0].ЭтоЗадача);
    Утверждения.ПроверитьЛожь(Список.Дети[0].Выполнено);
    Утверждения.ПроверитьИстину(Список.Дети[1].ЭтоЗадача);
    Утверждения.ПроверитьИстину(Список.Дети[1].Выполнено);
    Утверждения.ПроверитьЛожь(Список.Дети[2].ЭтоЗадача);
КонецПроцедуры

#КонецОбласти

#Область HTML_Рендеринг

&Тест
Процедура Тест_Задачи_HTML_НевыполненнаяИмеетЧекбокс() Экспорт
    HTML = Markdown.ВHTML("- [ ] Задача", GHНастройки());

    Утверждения.ПроверитьИстину(СтрНайти(HTML, "<input") > 0);
    Утверждения.ПроверитьИстину(СтрНайти(HTML, "type=""checkbox""") > 0);
    Утверждения.ПроверитьИстину(СтрНайти(HTML, "disabled=""""") > 0);
КонецПроцедуры

&Тест
Процедура Тест_Задачи_HTML_ВыполненнаяИмеетChecked() Экспорт
    HTML = Markdown.ВHTML("- [x] Сделано", GHНастройки());

    Утверждения.ПроверитьИстину(СтрНайти(HTML, "checked=""""") > 0);
КонецПроцедуры

&Тест
Процедура Тест_Задачи_HTML_НевыполненнаяНеИмеетChecked() Экспорт
    HTML = Markdown.ВHTML("- [ ] Задача", GHНастройки());

    Утверждения.ПроверитьЛожь(СтрНайти(HTML, "checked=""""") > 0,
        "Невыполненная задача не должна иметь checked");
КонецПроцедуры

&Тест
Процедура Тест_Задачи_HTML_МаркерНеПопадаетВТекст() Экспорт
    HTML = Markdown.ВHTML("- [ ] Задача один", GHНастройки());

    Утверждения.ПроверитьЛожь(СтрНайти(HTML, "[ ]") > 0,
        "Маркер [ ] не должен присутствовать в HTML");
    Утверждения.ПроверитьИстину(СтрНайти(HTML, "Задача один") > 0);
КонецПроцедуры

&Тест
Процедура Тест_Задачи_HTML_НеРаботаетБезРасширения() Экспорт
    // Настройки по умолчанию — расширение tasklists выключено.
    HTML = Markdown.ВHTML("- [ ] Задача");

    Утверждения.ПроверитьЛожь(СтрНайти(HTML, "type=""checkbox""") > 0,
        "Чекбокс не должен рендериться без расширения tasklists");
    Утверждения.ПроверитьИстину(СтрНайти(HTML, "[ ] Задача") > 0,
        "Текст маркера должен выводиться как обычный текст");
КонецПроцедуры

#КонецОбласти

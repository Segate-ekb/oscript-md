#Использовать asserts
#Использовать "../../src"

// Тесты HTML-рендерера: AST → HTML.
// Намеренно собираем AST вручную, чтобы развести «дефекты парсера» и «дефекты рендерера».

Перем Рендерер;

&ПередКаждым
Процедура Перед() Экспорт
    Рендерер = Новый MarkdownHTMLРендерер();
КонецПроцедуры

&Тест
Процедура Тест_HTML_Заголовок() Экспорт
    Документ = Новый MarkdownДокумент();
    Заголовок = Новый MarkdownЗаголовок(1);
    Заголовок.Добавить(Новый MarkdownТекст("Привет"));
    Документ.Добавить(Заголовок);

    HTML = Рендерер.Отрендерить(Документ);

    Утверждения.ПроверитьРавенство("<h1>Привет</h1>" + Символы.ПС, HTML);
КонецПроцедуры

&ПараметризованныйТест
&ИсточникЗначение(1, "<h1>foo</h1>")
&ИсточникЗначение(2, "<h2>foo</h2>")
&ИсточникЗначение(3, "<h3>foo</h3>")
&ИсточникЗначение(4, "<h4>foo</h4>")
&ИсточникЗначение(5, "<h5>foo</h5>")
&ИсточникЗначение(6, "<h6>foo</h6>")
Процедура Тест_HTML_УровниЗаголовков(Уровень, ОжидаемыйHTML) Экспорт
    Документ = Новый MarkdownДокумент();
    Заголовок = Новый MarkdownЗаголовок(Уровень);
    Заголовок.Добавить(Новый MarkdownТекст("foo"));
    Документ.Добавить(Заголовок);

    HTML = Рендерер.Отрендерить(Документ);

    Утверждения.ПроверитьРавенство(ОжидаемыйHTML + Символы.ПС, HTML);
КонецПроцедуры

&Тест
Процедура Тест_HTML_Параграф() Экспорт
    Документ = Новый MarkdownДокумент();
    Параграф = Новый MarkdownПараграф();
    Параграф.Добавить(Новый MarkdownТекст("hello"));
    Документ.Добавить(Параграф);

    HTML = Рендерер.Отрендерить(Документ);

    Утверждения.ПроверитьРавенство("<p>hello</p>" + Символы.ПС, HTML);
КонецПроцедуры

&Тест
Процедура Тест_HTML_ГоризонтальнаяЛиния() Экспорт
    Документ = Новый MarkdownДокумент();
    Документ.Добавить(Новый MarkdownГоризонтальнаяЛиния());

    HTML = Рендерер.Отрендерить(Документ);

    Утверждения.ПроверитьРавенство("<hr />" + Символы.ПС, HTML);
КонецПроцедуры

&Тест
Процедура Тест_HTML_НесколькоБлоков() Экспорт
    Документ = Новый MarkdownДокумент();
    Заголовок = Новый MarkdownЗаголовок(2);
    Заголовок.Добавить(Новый MarkdownТекст("title"));
    Документ.Добавить(Заголовок);

    Параграф = Новый MarkdownПараграф();
    Параграф.Добавить(Новый MarkdownТекст("body"));
    Документ.Добавить(Параграф);

    HTML = Рендерер.Отрендерить(Документ);

    Ожидаемый = "<h2>title</h2>" + Символы.ПС + "<p>body</p>" + Символы.ПС;
    Утверждения.ПроверитьРавенство(Ожидаемый, HTML);
КонецПроцедуры

&ПараметризованныйТест
&ИсточникЗначение("a & b",       "a &amp; b")
&ИсточникЗначение("a < b",       "a &lt; b")
&ИсточникЗначение("a > b",       "a &gt; b")
&ИсточникЗначение("""quoted""", "&quot;quoted&quot;")
Процедура Тест_HTML_ЭкранируетСпецСимволыВТексте(Сырой, Ожидаемый) Экспорт
    Документ = Новый MarkdownДокумент();
    Параграф = Новый MarkdownПараграф();
    Параграф.Добавить(Новый MarkdownТекст(Сырой));
    Документ.Добавить(Параграф);

    HTML = Рендерер.Отрендерить(Документ);

    Утверждения.ПроверитьРавенство("<p>" + Ожидаемый + "</p>" + Символы.ПС, HTML);
КонецПроцедуры

&Тест
Процедура Тест_HTML_ПустойДокументДаётПустуюСтроку() Экспорт
    Документ = Новый MarkdownДокумент();

    HTML = Рендерер.Отрендерить(Документ);

    Утверждения.ПроверитьРавенство("", HTML);
КонецПроцедуры

#Использовать asserts
#Использовать "../../src"

// Тесты JSON-рендерера AST.
// JSON удобно использовать как стабильный snapshot-формат для отладки парсера.

Перем Рендерер;

&ПередКаждым
Процедура Перед() Экспорт
    Рендерер = Новый MarkdownJSONРендерер();
КонецПроцедуры

Функция РазобратьJSON(Знач Текст)
    Чтение = Новый ЧтениеJSON();
    Чтение.УстановитьСтроку(Текст);
    Результат = ПрочитатьJSON(Чтение);
    Чтение.Закрыть();
    Возврат Результат;
КонецФункции

&Тест
Процедура Тест_JSON_СтруктураДокументаСЗаголовком() Экспорт
    Документ = Новый MarkdownДокумент();
    Заголовок = Новый MarkdownЗаголовок(1);
    Заголовок.Добавить(Новый MarkdownТекст("Привет"));
    Документ.Добавить(Заголовок);

    JSONТекст = Рендерер.Отрендерить(Документ);
    Результат = РазобратьJSON(JSONТекст);

    Утверждения.ПроверитьРавенство("document", Результат["type"]);
    Утверждения.ПроверитьРавенство(1, Результат["children"].Количество());

    H1 = Результат["children"][0];
    Утверждения.ПроверитьРавенство("heading", H1["type"]);
    Утверждения.ПроверитьРавенство(1, H1["level"]);
    Утверждения.ПроверитьРавенство(1, H1["children"].Количество());
    Утверждения.ПроверитьРавенство("text", H1["children"][0]["type"]);
    Утверждения.ПроверитьРавенство("Привет", H1["children"][0]["value"]);
КонецПроцедуры

&Тест
Процедура Тест_JSON_СтруктураПараграфаСТекстом() Экспорт
    Документ = Новый MarkdownДокумент();
    Параграф = Новый MarkdownПараграф();
    Параграф.Добавить(Новый MarkdownТекст("hello"));
    Документ.Добавить(Параграф);

    Результат = РазобратьJSON(Рендерер.Отрендерить(Документ));

    P = Результат["children"][0];
    Утверждения.ПроверитьРавенство("paragraph", P["type"]);
    Утверждения.ПроверитьРавенство("hello", P["children"][0]["value"]);
КонецПроцедуры

&Тест
Процедура Тест_JSON_ГоризонтальнаяЛинияБезДетей() Экспорт
    Документ = Новый MarkdownДокумент();
    Документ.Добавить(Новый MarkdownГоризонтальнаяЛиния());

    Результат = РазобратьJSON(Рендерер.Отрендерить(Документ));

    HR = Результат["children"][0];
    Утверждения.ПроверитьРавенство("thematic_break", HR["type"]);
    Утверждения.ПроверитьЛожь(HR.Свойство("children")
        И HR["children"].Количество() > 0,
        "Горизонтальная линия не должна иметь детей в JSON");
КонецПроцедуры

&Тест
Процедура Тест_JSON_ПустойДокументИмеетПустойМассивДетей() Экспорт
    Документ = Новый MarkdownДокумент();

    Результат = РазобратьJSON(Рендерер.Отрендерить(Документ));

    Утверждения.ПроверитьРавенство("document", Результат["type"]);
    Утверждения.ПроверитьРавенство(0, Результат["children"].Количество());
КонецПроцедуры

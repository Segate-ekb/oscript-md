#Использовать asserts
#Использовать "../../src"

// Тесты inline-расширений: strikethrough (~~text~~) и extended autolinks.
// Тестируются через фасад (сквозной рендеринг) и через AST (Markdown.Разобрать).

Функция GHНастройки()
    Возврат Markdown.НастройкиGitHubLike();
КонецФункции

#Область Зачёркивание

&Тест
Процедура Тест_Зачёркивание_ДвойнаяТильда() Экспорт
    HTML = Markdown.ВHTML("~~зачёркнуто~~", GHНастройки());

    Утверждения.ПроверитьИстину(СтрНайти(HTML, "<del>зачёркнуто</del>") > 0);
КонецПроцедуры

&Тест
Процедура Тест_Зачёркивание_ВнутриПараграфа() Экспорт
    HTML = Markdown.ВHTML("текст ~~удалён~~ продолжение", GHНастройки());

    Утверждения.ПроверитьИстину(СтрНайти(HTML, "<del>удалён</del>") > 0);
    Утверждения.ПроверитьИстину(СтрНайти(HTML, "текст") > 0);
    Утверждения.ПроверитьИстину(СтрНайти(HTML, "продолжение") > 0);
КонецПроцедуры

&Тест
Процедура Тест_Зачёркивание_ASTТипУзла() Экспорт
    Документ = Markdown.Разобрать("~~текст~~", GHНастройки());

    Параграф = Документ.Дети[0];
    Узел = Параграф.Дети[0];

    Утверждения.ПроверитьРавенство("strikethrough", Узел.ТипУзла());
КонецПроцедуры

&Тест
Процедура Тест_Зачёркивание_ASTСодержимое() Экспорт
    Документ = Markdown.Разобрать("~~текст~~", GHНастройки());

    Параграф = Документ.Дети[0];
    Узел = Параграф.Дети[0]; // strikethrough
    ТекстВнутри = Узел.Дети[0]; // text

    Утверждения.ПроверитьРавенство("text", ТекстВнутри.ТипУзла());
    Утверждения.ПроверитьРавенство("текст", ТекстВнутри.Значение);
КонецПроцедуры

&Тест
Процедура Тест_Зачёркивание_НеРаботаетБезРасширения() Экспорт
    // Настройки по умолчанию — расширение strikethrough выключено.
    HTML = Markdown.ВHTML("~~текст~~");

    Утверждения.ПроверитьЛожь(СтрНайти(HTML, "<del>") > 0,
        "del не должен рендериться без расширения strikethrough");
КонецПроцедуры

&Тест
Процедура Тест_Зачёркивание_ПустоеСодержимоеНеРаспознаётся() Экспорт
    // "~~~~" — пустое зачёркивание, не должно быть <del>.
    HTML = Markdown.ВHTML("~~~~", GHНастройки());

    Утверждения.ПроверитьЛожь(СтрНайти(HTML, "<del>") > 0,
        "Пустое ~~ не должно создавать del");
КонецПроцедуры

#КонецОбласти

#Область РасширенныеАвтоссылки

&Тест
Процедура Тест_Автоссылки_HTTPS() Экспорт
    HTML = Markdown.ВHTML("https://example.com", GHНастройки());

    Утверждения.ПроверитьИстину(СтрНайти(HTML, "<a href=""https://example.com"">") > 0);
КонецПроцедуры

&Тест
Процедура Тест_Автоссылки_HTTP() Экспорт
    HTML = Markdown.ВHTML("http://example.org", GHНастройки());

    Утверждения.ПроверитьИстину(СтрНайти(HTML, "<a href=""http://example.org"">") > 0);
КонецПроцедуры

&Тест
Процедура Тест_Автоссылки_WWW_ПолучаетHTTPСхему() Экспорт
    // www. без схемы → href должен содержать http://.
    HTML = Markdown.ВHTML("www.example.org", GHНастройки());

    Утверждения.ПроверитьИстину(СтрНайти(HTML, "<a href=""http://www.example.org"">") > 0);
КонецПроцедуры

&Тест
Процедура Тест_Автоссылки_ОбрезаетТочкуВКонце() Экспорт
    // Trailing punctuation должна обрезаться по правилам GFM.
    HTML = Markdown.ВHTML("https://example.com.", GHНастройки());

    Утверждения.ПроверитьИстину(СтрНайти(HTML, "<a href=""https://example.com"">") > 0,
        "Точка в конце URL должна быть отсечена");
КонецПроцедуры

&Тест
Процедура Тест_Автоссылки_ASTТипУзла() Экспорт
    Документ = Markdown.Разобрать("https://example.com", GHНастройки());

    Параграф = Документ.Дети[0];
    Узел = Параграф.Дети[0];

    Утверждения.ПроверитьРавенство("link", Узел.ТипУзла());
    Утверждения.ПроверитьРавенство("https://example.com", Узел.URL);
КонецПроцедуры

&Тест
Процедура Тест_Автоссылки_НеРаботаетБезРасширения() Экспорт
    // Настройки по умолчанию — расширение autolinks выключено.
    HTML = Markdown.ВHTML("https://example.com");

    Утверждения.ПроверитьЛожь(СтрНайти(HTML, "<a href=") > 0,
        "Ссылка не должна создаваться без расширения autolinks");
КонецПроцедуры

#КонецОбласти
